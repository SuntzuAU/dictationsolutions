---
import site from "../site.config.json";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | {site.siteName}</title>
    <meta name="robots" content="noindex" />
  </head>
  <body style="margin:0;font-family:system-ui,sans-serif;background:#fff;color:#111827;display:flex;align-items:center;justify-content:center;min-height:100vh">
    <div style="text-align:center;padding:48px 24px">
      <div style="font-size:72px;font-weight:900;color:#16a34a">404</div>
      <h1 style="font-size:24px;margin:0 0 12px">Page not found</h1>
      <p style="color:#6b7280;margin:0 0 24px">The page you are looking for does not exist or has moved.</p>
      <a href="/" style="background:#16a34a;color:#fff;border-radius:8px;padding:12px 24px;font-weight:700;font-size:15px;text-decoration:none">Back to home</a>
    </div>
  </body>
</html>

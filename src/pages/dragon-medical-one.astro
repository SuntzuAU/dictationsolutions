---
import manifest from "../data/image-manifest.json";
import site from "../site.config.json";
import ACForm from "../components/ACForm.astro";

const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";
function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}
function imgAlt(key) { return manifest[key]?.altText || key; }
const c = site.colours;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dragon Medical One Australia | Dictation Solutions Australia</title>
    <meta name="description" content="Dragon Medical One for Australian clinicians. Cloud-based medical speech recognition with speciality vocabularies, EHR integration, and dictation from any device. Contact Voice Recognition Australia for pricing." />
    <link rel="canonical" href="https://dictationsolutions.com.au/dragon-medical-one" />
    <style is:inline define:vars={{ bg: c.background, text: c.text, primary: c.primary, accent: c.accent, accentHover: c.accentHover, muted: c.muted, neutral: c.neutral }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      .page-header{background:var(--primary);color:white;padding:48px 0 40px}
      .breadcrumb{font-size:13px;color:#9ca3af;margin-bottom:16px}
      .breadcrumb a{color:#9ca3af;text-decoration:underline}
      h1{font-size:38px;line-height:1.15;margin:0 0 14px;letter-spacing:-0.025em}
      .intro{font-size:18px;color:#d1d5db;margin:0;line-height:1.6}
      section{padding:56px 0}
      .neutral-bg{background:var(--neutral)}
      .dark-bg{background:var(--primary);color:white}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:20px}
      .c6{grid-column:span 6}
      .c4{grid-column:span 4}
      .c7{grid-column:span 7}
      .c5{grid-column:span 5}
      .c12{grid-column:span 12}
      .card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:28px}
      .card h2,.card h3{margin:0 0 10px}
      .card p{color:var(--muted);margin:0 0 12px}
      .card ul{color:var(--muted);padding-left:20px;margin:0 0 16px;line-height:1.9}
      .tag{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;background:var(--accent);color:#fff;margin-bottom:12px;text-transform:uppercase;letter-spacing:.05em}
      .btn{display:inline-block;padding:12px 24px;border-radius:8px;font-weight:700;font-size:15px;cursor:pointer;transition:all .15s}
      .btn-primary{background:var(--accent);color:#fff}
      .btn-primary:hover{background:var(--accentHover)}
      .formbox{background:#fff;border-radius:16px;padding:28px}
      footer{background:#111827;color:#6b7280;padding:28px 0;font-size:14px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#4b5563;line-height:1.6;margin-top:12px;padding-top:12px;border-top:1px solid #1f2937}
      @media(max-width:900px){.c6,.c4,.c5,.c7{grid-column:span 12}h1{font-size:28px}}
      @media(max-width:600px){section{padding:36px 0}.card{padding:20px}}
    </style>
  </head>
  <body>
    <header style="position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:1px solid #e5e7eb;z-index:100">
      <div class="wrap" style="display:flex;align-items:center;justify-content:space-between;padding-top:10px;padding-bottom:10px;gap:16px">
        <a href="/"><img src="/logo.png" alt={site.siteName} onerror="this.style.display='none'" height="40" width="160" /></a>
        <nav style="display:flex;gap:20px;font-size:14px;font-weight:500;color:#374151">
          <a href="/">Home</a>
          <a href="/dragon-software">Dragon Software</a>
          <a href="/dragon-medical-one" style="color:#16a34a;font-weight:700">Medical</a>
          <a href="/dictation-equipment">Equipment</a>
          <a href="/support">Support</a>
        </nav>
        <a href="/#final-cta" style="background:#16a34a;color:#fff;border-radius:8px;padding:9px 18px;font-weight:700;font-size:14px">Get in Touch</a>
      </div>
    </header>

    <div class="page-header">
      <div class="wrap">
        <div class="breadcrumb"><a href="/">Home</a> &rsaquo; Dragon Medical One</div>
        <h1>Dragon Medical One</h1>
        <p class="intro">Cloud-based speech recognition designed specifically for healthcare documentation. Available in Australia through Voice Recognition Australia.</p>
      </div>
    </div>

    <main>
      <section>
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <h2 style="font-size:26px;margin:0 0 16px">What is Dragon Medical One?</h2>
              <p style="font-size:16px;color:#4b5563;margin:0 0 14px">Dragon Medical One is a cloud-based speech recognition platform developed by Nuance (Microsoft) specifically for healthcare documentation. Clinicians dictate directly into electronic health records, clinical notes, and patient documentation using their voice.</p>
              <p style="font-size:16px;color:#4b5563;margin:0 0 14px">Unlike Dragon Professional, which is a general-purpose desktop product, Dragon Medical One includes built-in medical speciality vocabularies covering cardiology, radiology, pathology, oncology, emergency medicine, general practice, and many others.</p>
              <p style="font-size:16px;color:#4b5563;margin:0 0 24px">It is a subscription service - there is no local installation required. Clinicians can dictate from a desktop, laptop, tablet, or mobile device with an internet connection.</p>
              <h3 style="font-size:20px;margin:0 0 12px">Who uses Dragon Medical One in Australia?</h3>
              <p style="font-size:16px;color:#4b5563;margin:0 0 14px">Dragon Medical One is used by general practitioners, specialists, radiologists, pathologists, and other clinicians who need to produce clinical documentation efficiently. It is particularly well suited to practices where doctors are responsible for their own documentation rather than using a transcription service.</p>
              <p style="font-size:16px;color:#4b5563">For Australian pricing and purchasing, <a href="https://www.voicerecognition.com.au" style="color:#16a34a;font-weight:600">Voice Recognition Australia</a> is the authorised Nuance/Microsoft reseller. Pricing is subscription-based per user per year - contact VRA directly for current rates.</p>
            </div>
            <div class="c5">
              <div class="card">
                <div class="tag">Healthcare</div>
                <h3 style="font-size:18px">Dragon Medical One - key features</h3>
                <ul>
                  <li>Built-in medical speciality vocabularies</li>
                  <li>Cloud-based - dictate from any device</li>
                  <li>EHR and EMR workflow integration</li>
                  <li>No local installation or training required</li>
                  <li>Automatic profile sync across devices</li>
                  <li>Enterprise management and reporting</li>
                  <li>Available in Australian English</li>
                </ul>
                <a href="https://www.voicerecognition.com.au" class="btn btn-primary" style="display:block;text-align:center;margin-top:8px">Get Australian pricing from VRA</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <h2 style="font-size:26px;margin:0 0 24px">Dragon Medical One vs Dragon Medical Practice Edition</h2>
          <div class="grid">
            <div class="card c6">
              <div class="tag">Current</div>
              <h3>Dragon Medical One</h3>
              <p>Cloud-based. Subscription per user per year. No local installation. Works from any device with internet. Automatic vocabulary updates. Enterprise management tools. Active product with ongoing development.</p>
            </div>
            <div class="card c6">
              <div class="tag" style="background:#6b7280">Legacy</div>
              <h3>Dragon Medical Practice Edition</h3>
              <p>Locally installed Windows software. Perpetual licence. Requires local installation and voice profile training. No longer actively developed or sold. If you are running DMPE, migration to Dragon Medical One is the recommended upgrade path.</p>
            </div>
          </div>
          <p style="color:#6b7280;font-size:14px;margin-top:20px">For migration assistance from Dragon Medical Practice Edition, contact <a href="https://www.voicerecognition.com.au" style="color:#16a34a">Voice Recognition Australia</a>.</p>
        </div>
      </section>

      <section id="contact" class="dark-bg">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <h2 style="color:white;font-size:26px;margin:0 0 12px">Enquire about Dragon Medical One</h2>
              <p style="color:#9ca3af;margin:0 0 16px">Our team can advise on Dragon Medical One pricing, deployment, EHR compatibility, and setup for Australian healthcare environments.</p>
              <ul style="color:#9ca3af;padding-left:20px;line-height:2;font-size:15px">
                <li>Current Australian pricing</li>
                <li>EHR and EMR compatibility</li>
                <li>Microphone recommendations</li>
                <li>Migration from older Dragon Medical products</li>
              </ul>
            </div>
            <div class="c5">
              <ACForm />
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">
            <a href="/">Home</a>
            <a href="/dragon-software">Dragon Software</a>
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
          </div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>
  </body>
</html>

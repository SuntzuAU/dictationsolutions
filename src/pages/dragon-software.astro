---
import site from "../site.config.json";
import manifest from "../data/image-manifest.json";
import ACForm from "../components/ACForm.astro";

const product = site.products.find(p => p.slug === 'dragon-professional-16') || site.products[0];
const c = site.colours;
const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}
function imgAlt(key) { return manifest[key]?.altText || ""; }
function homeUrl(url) {
  if (!url) return "/";
  return url.startsWith("#") ? `/${url}` : url;
}

const heroKey = "hero";
const featureKey = "feature-dictation";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dragon Software Australia | Speech Recognition | Dictation Solutions</title>
    <meta name="description" content="Dragon speech recognition software for Australian professionals. Dragon Professional 16, Dragon Medical One, Dragon Professional Anywhere. Authorised reseller." />
    <link rel="canonical" href={`${site.domain}/dragon-software`} />
    <style is:inline define:vars={{ bg: c.background, text: c.text, primary: c.primary, accent: c.accent, accentHover: c.accentHover, muted: c.muted, neutral: c.neutral }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:2px solid var(--accent);z-index:200;overflow:visible}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}
      .logo img{height:42px;width:auto}
      .nav-links{display:flex;gap:20px;font-size:14px;font-weight:600;color:#374151;align-items:center}
      .nav-links > a{white-space:nowrap;padding:4px 0;border-bottom:2px solid transparent;transition:color .15s,border-color .15s}
      .nav-links > a:hover{color:var(--accent);border-bottom-color:var(--accent)}
      .dropdown{position:relative}
      .dropdown-toggle{cursor:pointer;display:flex;align-items:center;gap:4px;white-space:nowrap;padding:4px 0;border-bottom:2px solid transparent;transition:color .15s,border-color .15s}
      .dropdown-toggle:hover,.dropdown:hover .dropdown-toggle{color:var(--accent);border-bottom-color:var(--accent)}
      .dropdown-toggle svg{transition:transform .2s;flex-shrink:0}
      .dropdown:hover .dropdown-toggle svg{transform:rotate(180deg)}
      .dropdown-menu{display:none;position:absolute;top:calc(100% + 6px);left:0;background:#fff;border:1px solid #e5e7eb;border-top:3px solid var(--accent);border-radius:0 0 12px 12px;box-shadow:0 12px 40px rgba(0,0,0,.12);min-width:230px;padding:6px 0;z-index:300}
      .dropdown:hover .dropdown-menu{display:block}
      .dropdown-menu a{display:block;padding:11px 18px;font-size:13px;font-weight:600;color:#374151;transition:background .1s,color .1s;border-bottom:1px solid #f3f4f6}
      .dropdown-menu a:last-child{border-bottom:none}
      .dropdown-menu a:hover{background:#f0f9ff;color:var(--accent)}
      .nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;text-align:center}
      .btn-primary{background:var(--accent);border-color:var(--accent);color:#fff}
      .btn-primary:hover{background:var(--accentHover);border-color:var(--accentHover);transform:translateY(-1px)}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}
      .btn-dark{background:#1f2937;border-color:#1f2937;color:#fff}
      .btn-dark:hover{background:#374151;border-color:#374151}
      .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}
      .hamburger span{display:block;width:22px;height:2px;background:#374151;border-radius:2px}
      .mobile-nav{display:none;padding:10px 0 8px;border-top:1px solid #e5e7eb}
      .mobile-nav a{display:block;padding:10px 4px;font-size:15px;font-weight:600;color:#374151;border-bottom:1px solid #f3f4f6}
      .mobile-nav a.sub{padding-left:16px;font-weight:500;font-size:14px;color:#6b7280}
      section{padding:22px 0}
      .page-hero{padding:36px 0 32px;background:linear-gradient(135deg,#1a2f5e 0%,#1e3a5f 60%,#16a34a 100%);color:white}
      .page-hero h1{font-size:36px;line-height:1.1;margin:0 0 12px;letter-spacing:-0.03em;font-weight:800;color:white}
      .page-hero p{font-size:16px;color:rgba(255,255,255,.8);margin:0 0 24px;line-height:1.65;max-width:560px}
      .page-hero-btns{display:flex;gap:12px;flex-wrap:wrap}
      .section-divider{height:4px;background:linear-gradient(90deg,var(--accent),var(--primary))}
      .sh{margin-bottom:20px}
      .sh h2{font-size:26px;letter-spacing:-0.02em;margin:0 0 6px;font-weight:800}
      .sh p{font-size:15px;margin:0;color:var(--muted)}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}.c4{grid-column:span 4}.c5{grid-column:span 5}.c7{grid-column:span 7}.c3{grid-column:span 3}.c12{grid-column:span 12}
      .section-white{background:#fff}.section-neutral{background:var(--neutral)}.section-dark{background:var(--primary);color:white}
      .product-card{background:#fff;border:2px solid #e5e7eb;border-radius:16px;padding:22px;display:flex;flex-direction:column;text-decoration:none;color:inherit;transition:border-color .15s,box-shadow .15s,transform .15s}
      .product-card:hover{border-color:var(--accent);box-shadow:0 8px 24px rgba(22,163,74,.15);transform:translateY(-2px)}
      .product-badge{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;margin-bottom:8px;text-transform:uppercase;letter-spacing:.05em;background:var(--accent);color:#fff}
      .product-title{font-size:17px;font-weight:700;margin:0 0 4px}
      .product-for{font-size:13px;color:#64748b;margin:0 0 10px}
      .product-price{font-size:26px;font-weight:800;color:var(--accent);margin:0 0 4px}
      .product-pricenote{font-size:12px;color:#64748b;margin:0 0 14px}
      .product-cta{margin-top:auto;display:block;text-align:center;padding:10px 16px;border-radius:8px;font-weight:700;font-size:14px;background:#f1f5f9;color:#1a1a1a;transition:background .15s}
      .product-card:hover .product-cta{background:var(--accent);color:#fff}
      .formbox{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:14px;padding:20px}
      footer{background:#0f172a;color:#6b7280;padding:16px 0;font-size:13px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#374151;line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid #1e293b}
      @media(max-width:900px){.c6,.c4,.c5,.c7,.c3{grid-column:span 12}.page-hero h1{font-size:26px}}
      @media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}section{padding:14px 0}.page-hero{padding:24px 0 20px}.footer-inner{flex-direction:column;align-items:center;text-align:center}.footer-links{justify-content:center}}
    </style>
  </head>
  <body>
    <header>
      <div class="wrap">
        <div class="nav">
          <div class="logo"><a href="/"><img src="/logo.png" alt={site.siteName} onerror="this.style.display='none'" width="160" height="40" /></a></div>
          <nav class="nav-links" aria-label="Primary">
            {site.navItems?.map((item) => <a href={homeUrl(item.url)}>{item.label}</a>)}
            {site.navDropdown && (
              <div class="dropdown">
                <span class="dropdown-toggle">{site.navDropdown.label}<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
                <div class="dropdown-menu">
                  {site.navDropdown.items?.map((item) => <a href={item.url}>{item.label}</a>)}
                  <a href="/comparison">Compare Solutions</a>
                </div>
              </div>
            )}
            <a href="/news">News</a>
          </nav>
          <div class="nav-ctas">
            <a class="btn btn-primary" href="/#final-cta">{site.primaryCTA.text}</a>
            <button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'"><span></span><span></span><span></span></button>
          </div>
        </div>
        <nav class="mobile-nav" aria-label="Mobile navigation">
          <a href="/">Home</a>
          {site.navDropdown?.items?.map((item) => <a class="sub" href={item.url}>{item.label}</a>)}
          {site.navItems?.map((item) => <a href={homeUrl(item.url)}>{item.label}</a>)}
          <a href="/news">News</a><a href="/comparison">Compare Solutions</a>
        </nav>
      </div>
    </header>
    <main>
      <section class="page-hero">
        <div class="wrap">
          <h1>Dragon Speech Recognition Software</h1>
          <p>The full range of Dragon software products for Australian professionals. Desktop, cloud, and medical editions from an authorised Nuance/Microsoft reseller.</p>
          <div class="page-hero-btns">
            <a href="/#final-cta" class="btn btn-primary btn-lg">Get a Quote</a>
            <a href="/comparison" class="btn btn-dark btn-lg">Compare Products</a>
          </div>
        </div>
      </section>
      <div class="section-divider"></div>
      <section class="section-neutral">
        <div class="wrap">
          <div class="sh"><h2>All Dragon products</h2><p>Choose the right Dragon edition for your workflow.</p></div>
          <div class="grid">
            {site.products?.filter(p => p.slug !== 'cloud-speech-solutions' && p.slug !== 'transcription-services' && p.slug !== 'dictation-hardware').map(p => (
              <a href={`/${p.slug}`} class="product-card c4">
                <div class="product-badge">{p.badge}</div>
                <div class="product-title">{p.title}</div>
                <div class="product-for">{p.bestFor}</div>
                <div class="product-price">{p.price}</div>
                <div class="product-pricenote">{p.priceNote}</div>
                <div class="product-cta">View details &rarr;</div>
              </a>
            ))}
          </div>
        </div>
      </section>
      <section id="final-cta" class="section-dark">
        <div class="wrap">
          <div class="grid" style="align-items:start">
            <div class="c7" style="padding:20px 0">
              <h2 style="color:white;font-size:24px;margin:0 0 8px;font-weight:800">Not sure which Dragon product?</h2>
              <p style="color:rgba(255,255,255,.75);margin:0 0 18px;font-size:14px;line-height:1.65">Our team has been deploying Dragon in Australian healthcare, legal, and enterprise environments for 25 years. Tell us your situation and we'll recommend the right edition.</p>
            </div>
            <div class="c5" style="padding:20px 0"><div class="formbox"><ACForm /></div></div>
          </div>
        </div>
      </section>
    </main>
    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">{site.footerLinks?.map((l) => <a href={homeUrl(l.url)}>{l.label}</a>)}</div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>
  </body>
</html>

---
import manifest from "../data/image-manifest.json";
import site from "../site.config.json";
import ACForm from "../components/ACForm.astro";
import Nav from "../components/Nav.astro";

const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}
function imgAlt(key) {
  return manifest[key]?.altText || key;
}

const c = site.colours;
const product = site.products.find(p => p.slug === 'philips-speechlive');
const canonicalUrl = `${site.domain}/philips-speechlive`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.title,
  "description": product.metaDesc,
  "brand": { "@type": "Brand", "name": "Philips" },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "AUD",
    "price": "0",
    "priceSpecification": { "@type": "PriceSpecification", "description": product.priceNote },
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": site.siteName }
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{product.metaTitle}</title>
    <meta name="description" content={product.metaDesc} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={product.metaTitle} />
    <meta property="og:description" content={product.metaDesc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_AU" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <style is:inline define:vars={{
      bg: c.background,
      text: c.text,
      primary: c.primary,
      accent: c.accent,
      accentHover: c.accentHover,
      muted: c.muted,
      neutral: c.neutral,
    }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;text-align:center}
      .btn-primary{background:var(--accent);border-color:var(--accent);color:#fff}
      .btn-primary:hover{background:var(--accentHover);border-color:var(--accentHover)}
      .btn-secondary{background:white;border-color:#cbd5e1;color:var(--primary)}
      .btn-secondary:hover{border-color:var(--primary)}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}
      section{padding:64px 0}
      .hero{padding:72px 0 48px;background:var(--neutral)}
      .neutral-bg{background:var(--neutral)}
      .dark-bg{background:var(--primary);color:white}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}
      .c4{grid-column:span 4}
      .c7{grid-column:span 7}
      .c5{grid-column:span 5}
      .c12{grid-column:span 12}
      .pill{display:inline-flex;align-items:center;background:#dcfce7;border:1px solid #86efac;color:#14532d;border-radius:999px;padding:5px 12px;font-size:12px;font-weight:600;margin-bottom:14px}
      h1{font-size:38px;line-height:1.1;margin:0 0 14px;letter-spacing:-0.03em;font-weight:800}
      .lead{font-size:17px;margin:0 0 28px;line-height:1.7;color:var(--muted)}
      .hero-btns{display:flex;gap:12px;flex-wrap:wrap}
      .sh{margin-bottom:32px}
      .sh h2{font-size:28px;letter-spacing:-0.02em;margin:0 0 8px;font-weight:800}
      .sh p{font-size:16px;margin:0;color:var(--muted)}
      .card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:22px}
      .card p{color:var(--muted);font-size:15px;line-height:1.6;margin:0}
      .feature-list{list-style:none;margin:0;padding:0}
      .feature-list li{padding:10px 0;border-bottom:1px solid #f1f5f9;font-size:15px;display:flex;gap:10px;align-items:flex-start;color:var(--text)}
      .feature-list li:last-child{border-bottom:none}
      .feature-list li::before{content:"\2713";color:var(--accent);font-weight:800;flex-shrink:0;margin-top:1px}
      .faq-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:22px}
      .faq-card h3{margin:0 0 8px;font-size:16px;font-weight:700;color:var(--primary)}
      .faq-card p{margin:0;font-size:15px;color:var(--muted);line-height:1.55}
      .breadcrumb{font-size:13px;color:var(--muted);margin-bottom:16px}
      .breadcrumb a{color:var(--accent)}
      footer{background:#111;color:#64748b;padding:28px 0;font-size:14px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#475569;line-height:1.6;margin-top:12px;padding-top:12px;border-top:1px solid #222}
      @media(max-width:900px){
        h1{font-size:28px}
        .c6,.c4,.c5,.c7{grid-column:span 12}
        .sh h2{font-size:22px}
      }
      @media(max-width:600px){
        section{padding:40px 0}
        .hero{padding:36px 0 28px}
        h1{font-size:24px}
        .hero-btns{flex-direction:column}
        .hero-btns .btn-lg{width:100%;text-align:center}
        .card,.faq-card{padding:16px}
        .footer-inner{flex-direction:column;align-items:center;text-align:center}
        .footer-links{justify-content:center}
      }
    </style>
  </head>
  <body>

    <Nav />

    <main>

      <section class="hero">
        <div class="wrap">
          <div class="breadcrumb"><a href="/">Home</a> &rsaquo; Philips SpeechLive</div>
          <div class="pill">Cloud Dictation Workflow &bull; Australia</div>
          <h1>{product.headline}</h1>
          <p class="lead">{product.subheadline}</p>
          <div class="hero-btns">
            <a class="btn btn-primary btn-lg" href="#contact">Enquire About SpeechLive</a>
            <a class="btn btn-secondary btn-lg" href="/dictation-hardware">View Philips Hardware</a>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <div class="sh">
                <h2>What Philips SpeechLive does</h2>
                <p>A cloud platform that connects your dictation devices, speech recognition, and transcription workflow in one place.</p>
              </div>
              <ul class="feature-list">
                {product.features?.map(f => <li>{f}</li>)}
              </ul>
            </div>
            <div class="c5">
              <div class="card" style="background:var(--neutral);border:none">
                <h3 style="margin:0 0 16px;font-size:17px;font-weight:700">Licensing & access</h3>
                <div style="margin-bottom:12px">
                  <div style="font-size:13px;color:var(--muted);margin-bottom:2px">Pricing</div>
                  <div style="font-size:24px;font-weight:800;color:var(--accent)">{product.price}</div>
                  <div style="font-size:13px;color:var(--muted)">{product.priceNote}</div>
                </div>
                <div style="margin-bottom:12px">
                  <div style="font-size:13px;color:var(--muted);margin-bottom:2px">Licence type</div>
                  <div style="font-size:15px;font-weight:600">{product.licenceNote}</div>
                </div>
                <div style="margin-bottom:20px">
                  <div style="font-size:13px;color:var(--muted);margin-bottom:2px">Device access</div>
                  <div style="font-size:15px;font-weight:600">{product.installLimit}</div>
                </div>
                <a class="btn btn-primary" href="#contact" style="width:100%;display:block;text-align:center">Enquire About SpeechLive</a>
                <a href="https://www.voicerecognition.com.au" style="display:block;text-align:center;margin-top:10px;font-size:13px;color:var(--muted)">Visit Voice Recognition Australia &rarr;</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="neutral-bg">
        <div class="wrap">
          <div class="sh">
            <h2>How SpeechLive fits your workflow</h2>
            <p>Whether you are a solo practitioner or a multi-site team, SpeechLive adapts to your existing dictation process.</p>
          </div>
          <div class="grid">
            <div class="card c4">
              <h3 style="margin:0 0 8px;font-size:17px;font-weight:700">Dictate anywhere</h3>
              <p>Use a Philips SpeechMike at your desk, the DataVoice app on your phone, or the browser interface. All recordings land in your secure cloud queue.</p>
            </div>
            <div class="card c4">
              <h3 style="margin:0 0 8px;font-size:17px;font-weight:700">Route to transcription</h3>
              <p>Dictations are automatically routed to your transcriptionist pool or to Dragon speech recognition for automated conversion - with priority and deadline rules.</p>
            </div>
            <div class="card c4">
              <h3 style="margin:0 0 8px;font-size:17px;font-weight:700">Deliver finished documents</h3>
              <p>Completed transcripts return to the author for review and approval. The full audit trail is maintained for compliance and billing purposes.</p>
            </div>
          </div>
          <p style="margin-top:20px;font-size:14px;color:var(--muted)">
            Teams who prefer a browser-only approach with no hardware may also consider <a href="https://www.speechrecognition.cloud" style="color:var(--accent);font-weight:600">best speech recognition software</a> via SpeechRecognition.cloud as a lighter alternative.
          </p>
        </div>
      </section>

      <section id="faq">
        <div class="wrap">
          <div class="sh">
            <h2>Frequently asked questions</h2>
          </div>
          <div class="grid">
            {product.faqs?.map(f => (
              <div class="faq-card c6">
                <h3>{f.q}</h3>
                <p>{f.a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="contact" class="dark-bg">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <h2 style="color:white;font-size:26px;margin:0 0 12px;font-weight:800">Enquire about Philips SpeechLive</h2>
              <p style="color:#94a3b8;margin:0 0 20px;font-size:15px;line-height:1.65">
                Tell us about your current dictation workflow and team size. We will recommend the right SpeechLive configuration and connect you with Australian pricing.
              </p>
              <ul style="color:#94a3b8;margin:0;padding-left:20px;line-height:2.2;font-size:15px">
                <li>Your current dictation hardware or software</li>
                <li>Number of authors and transcriptionists</li>
                <li>Industry - healthcare, legal, government or other</li>
                <li>Integration requirements (Dragon, DMS, EMR)</li>
              </ul>
            </div>
            <div class="c5">
              <ACForm />
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">
            {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
          </div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>

  </body>
</html>

---
import site from "../site.config.json";
import manifest from "../data/image-manifest.json";
import ACForm from "../components/ACForm.astro";

const c = site.colours;
const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";
const primaryColour = c.primary || "#1f2937";
const accentColour = c.accent || "#16a34a";

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}
function imgAlt(key) { return manifest[key]?.altText || ""; }
function homeUrl(url) {
  if (!url) return "/";
  return url.startsWith("#") ? `/${url}` : url;
}

const heroSrc = imgSrc("src-hero");
const featureSrc = imgSrc("src-feature");
const metaTitle = "SpeechRecognition.cloud - AI Speech-to-Text Software for Windows | Dictation Solutions Australia";
const metaDesc = "SpeechRecognition.cloud is a Windows speech recognition app with no voice training required. Free edition available. Professional and Medical Ultra editions for Australian businesses and healthcare. Download and start dictating in minutes.";
const downloadUrl = "https://download.speechrecognition.cloud/src/SpeechRecognitionCloudInstaller.exe";
const buyUrl = "https://www.voicerecognition.com.au/collections/speech-to-text-software";
const dragonBuyUrl = "https://www.voicerecognition.com.au/collections/dragon-professional";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDesc} />
    <link rel="canonical" href={`${site.domain}/speech-recognition-cloud`} />
    {site.googleAnalyticsId && (<script async src={`https://www.googletagmanager.com/gtag/js?id=${site.googleAnalyticsId}`}></script><script define:vars={{ gaId: site.googleAnalyticsId }}>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config',gaId);</script>)}
    <style is:inline define:vars={{ bg: c.background, text: c.text, primary: c.primary, accent: c.accent, accentHover: c.accentHover, muted: c.muted, neutral: c.neutral }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:2px solid var(--accent);z-index:200}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}
      .logo img{height:42px;width:auto}
      .nav-links{display:flex;gap:20px;font-size:14px;font-weight:600;color:#374151;align-items:center}
      .nav-links > a{white-space:nowrap;padding:4px 0;border-bottom:2px solid transparent;transition:color .15s,border-color .15s}
      .nav-links > a:hover{color:var(--accent);border-bottom-color:var(--accent)}
      .dropdown{position:relative}
      .dropdown-toggle{cursor:pointer;display:flex;align-items:center;gap:4px;white-space:nowrap;padding:4px 0;}
      .dropdown-toggle:hover,.dropdown:hover .dropdown-toggle{color:var(--accent)}
      .dropdown-toggle svg{transition:transform .2s;flex-shrink:0}
      .dropdown:hover .dropdown-toggle svg{transform:rotate(180deg)}
      .dropdown-menu{display:none;position:fixed;top:auto;left:auto;background:#fff;border:1px solid #e5e7eb;border-top:3px solid var(--accent);border-radius:0 0 12px 12px;box-shadow:0 12px 40px rgba(0,0,0,.12);min-width:230px;padding:6px 0;z-index:9999}
      .dropdown:hover .dropdown-menu{display:block}
      .dropdown-menu a{display:block;padding:11px 18px;font-size:13px;font-weight:600;color:#374151;transition:background .1s,color .1s;border-bottom:1px solid #f3f4f6}
      .dropdown-menu a:last-child{border-bottom:none}
      .dropdown-menu a:hover{background:#f0f9ff;color:var(--accent)}
      .nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;text-align:center}
      .btn-primary{background:var(--accent);border-color:var(--accent);color:#fff}
      .btn-primary:hover{background:var(--accentHover);border-color:var(--accentHover);transform:translateY(-1px)}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}
      .btn-outline{background:transparent;border:2px solid white;color:white}
      .btn-outline:hover{background:rgba(255,255,255,.1)}
      .btn-dark{background:#1f2937;border-color:#1f2937;color:#fff}
      .btn-dark:hover{background:#374151;border-color:#374151}
      .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}
      .hamburger span{display:block;width:22px;height:2px;background:#374151;border-radius:2px}
      .mobile-nav{display:none;padding:10px 0 8px;border-top:1px solid #e5e7eb}
      .mobile-nav a{display:block;padding:10px 4px;font-size:15px;font-weight:600;color:#374151;border-bottom:1px solid #f3f4f6}
      .mobile-nav a.sub{padding-left:16px;font-weight:500;font-size:14px;color:#6b7280}
      section{padding:28px 0}
      .page-hero{padding:36px 0 40px;background:linear-gradient(135deg,#1a2f5e 0%,#1e3a5f 55%,#16a34a 100%);color:white}
      .page-hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center}
      .breadcrumb{font-size:12px;color:rgba(255,255,255,.6);margin-bottom:16px;font-weight:500}
      .breadcrumb a{color:rgba(255,255,255,.85);font-weight:600}
      .breadcrumb-sep{margin:0 6px;color:rgba(255,255,255,.4)}
      .page-hero h1{font-size:34px;line-height:1.1;margin:0 0 14px;letter-spacing:-0.03em;font-weight:800;color:white}
      .page-hero .subhead{font-size:16px;line-height:1.65;margin:0 0 24px;color:rgba(255,255,255,.85)}
      .hero-actions{display:flex;gap:12px;flex-wrap:wrap;align-items:center}
      .pill-badge{display:inline-block;font-size:12px;font-weight:700;padding:5px 14px;border-radius:999px;background:var(--accent);color:#fff;margin-bottom:16px;text-transform:uppercase;letter-spacing:.06em}
      .hero-img{border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 50px rgba(0,0,0,.3)}
      .hero-img img{width:100%;height:100%;object-fit:cover;display:block}
      .stats-stripe{background:rgba(255,255,255,.1);border-top:1px solid rgba(255,255,255,.15);margin-top:28px;padding:16px 0}
      .stats-row{display:flex;gap:32px;flex-wrap:wrap}
      .stat-item{text-align:center}
      .stat-val{font-size:22px;font-weight:800;color:#fff;line-height:1}
      .stat-lbl{font-size:11px;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.05em;margin-top:3px}
      .sh{margin-bottom:18px}
      .sh h2{font-size:26px;letter-spacing:-0.02em;margin:0 0 6px;font-weight:800}
      .sh p{font-size:15px;margin:0;color:var(--muted)}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:20px}
      .c6{grid-column:span 6}.c4{grid-column:span 4}.c5{grid-column:span 5}.c7{grid-column:span 7}.c12{grid-column:span 12}.c3{grid-column:span 3}
      .section-white{background:#fff}.section-neutral{background:var(--neutral)}
      .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:22px}
      .card h3{font-size:16px;font-weight:700;margin:0 0 8px;color:var(--primary)}
      .card p{font-size:14px;margin:0;color:var(--muted);line-height:1.6}
      .feature-list{list-style:none;padding:0;margin:0}
      .feature-list li{padding:9px 0;border-bottom:1px solid #f3f4f6;font-size:14px;display:flex;gap:10px;align-items:flex-start;line-height:1.5}
      .feature-list li:last-child{border-bottom:none}
      .feature-check{color:var(--accent);font-weight:700;flex-shrink:0;font-size:15px}
      .feature-img{border-radius:12px;overflow:hidden;box-shadow:0 8px 24px rgba(0,0,0,.08)}
      .feature-img img{width:100%;height:auto;display:block}
      .plan-card{background:#fff;border:2px solid #e5e7eb;border-radius:16px;padding:24px;display:flex;flex-direction:column}
      .plan-card.highlight{border-color:var(--accent);box-shadow:0 0 0 3px rgba(22,163,74,.1)}
      .plan-name{font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:8px}
      .plan-price{font-size:36px;font-weight:800;color:var(--primary);line-height:1;margin-bottom:2px}
      .plan-period{font-size:13px;color:var(--muted);margin-bottom:6px}
      .plan-tag{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;background:var(--accent);color:#fff;margin-bottom:14px}
      .plan-features{list-style:none;padding:0;margin:0 0 20px;flex:1}
      .plan-features li{font-size:13px;padding:6px 0;border-bottom:1px solid #f3f4f6;color:#374151;display:flex;gap:8px}
      .plan-features li:last-child{border-bottom:none}
      .plan-features .ck{color:var(--accent);font-weight:700;flex-shrink:0}
      /* Comparison table */
      .compare-wrap{overflow-x:auto}
      .compare-table{width:100%;border-collapse:collapse;font-size:14px;min-width:600px}
      .compare-table th{padding:14px 16px;font-weight:700;font-size:13px;text-align:center;vertical-align:bottom;border-bottom:2px solid #e5e7eb}
      .compare-table th:first-child{text-align:left;background:var(--primary);color:white;border-bottom:2px solid var(--primary)}
      .compare-table th.col-src{background:var(--accent);color:#fff;border-bottom:2px solid var(--accentHover)}
      .compare-table th.col-other{background:#f1f5f9;color:#374151}
      .compare-table .group-row td{background:var(--primary);color:white;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:8px 16px}
      .compare-table .group-row td.src-col{background:var(--accent)}
      .compare-table .group-row td.other-col{background:#374151}
      .compare-table td{padding:11px 16px;border-bottom:1px solid #e5e7eb;vertical-align:middle;text-align:center}
      .compare-table td:first-child{text-align:left;font-weight:600;color:#374151;background:#fff}
      .compare-table td.src-col{background:#f0fdf4;font-weight:600}
      .compare-table tr:hover td:first-child{background:#f9fafb}
      .compare-table tr:hover td.src-col{background:#dcfce7}
      .yes{color:var(--accent);font-weight:700}
      .no{color:#9ca3af}
      .compare-table .cta-row td{padding:14px 16px;border-bottom:none}
      .compare-table .cta-row td.src-col{background:#f0fdf4}
      .compare-table .cta-row td:first-child{background:#fff}
      .compare-table .cta-row td.other-col{background:#f9fafb}
      .col-header-sub{display:block;font-size:11px;font-weight:500;opacity:.8;margin-top:3px}
      .best-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:999px;background:rgba(255,255,255,.25);color:#fff;margin-bottom:4px;text-transform:uppercase;letter-spacing:.05em}
      .use-case-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
      .use-case{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:18px;border-top:3px solid var(--accent)}
      .use-case h3{font-size:15px;font-weight:700;margin:0 0 8px;color:var(--primary)}
      .use-case p{font-size:13px;color:var(--muted);margin:0;line-height:1.6}
      .faq-card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:18px;border-left:4px solid var(--accent)}
      .faq-card h3{margin:0 0 6px;font-size:14px;font-weight:700;color:var(--primary)}
      .faq-card p{margin:0;font-size:13px;color:var(--muted);line-height:1.6}
      .also-section{background:var(--neutral);padding:20px 0}
      .other-versions{display:flex;flex-wrap:wrap;gap:10px;margin-top:6px}
      .other-version-link{padding:8px 16px;border-radius:8px;border:2px solid #e5e7eb;font-size:13px;font-weight:600;color:#374151;transition:all .15s}
      .other-version-link:hover{border-color:var(--accent);color:var(--accent)}
      .section-divider{height:4px;background:linear-gradient(90deg,var(--accent),var(--primary))}
      footer{background:#0f172a;color:#6b7280;padding:16px 0;font-size:13px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#374151;line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid #1e293b}
      @media(max-width:900px){.page-hero-inner{grid-template-columns:1fr}.use-case-grid{grid-template-columns:1fr 1fr}.c6,.c4,.c5,.c7,.c3{grid-column:span 6}.sh h2{font-size:22px}.page-hero h1{font-size:26px}.stats-row{gap:20px}}
      @media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}section{padding:18px 0}.page-hero{padding:22px 0 26px}.use-case-grid{grid-template-columns:1fr}.c6,.c4,.c5,.c7,.c3{grid-column:span 12}.hero-actions{flex-direction:column}.hero-actions .btn-lg{width:100%;text-align:center}.footer-inner{flex-direction:column;align-items:center;text-align:center}.footer-links{justify-content:center}.stats-row{gap:14px}}
    </style>
  </head>
  <body>
    <header>
      <div class="wrap">
        <div class="nav">
          <div class="logo"><a href="/"><img src="/logo.png" alt={site.siteName} onerror="this.style.display='none'" width="160" height="40" /></a></div>
          <nav class="nav-links" aria-label="Primary">
            {site.navItems?.map((item) => <a href={homeUrl(item.url)}>{item.label}</a>)}
            {site.navDropdown && (<div class="dropdown"><span class="dropdown-toggle">{site.navDropdown.label}<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span><div class="dropdown-menu">{site.navDropdown.items?.map((item) => <a href={item.url}>{item.label}</a>)}<a href="/comparison">Compare Solutions</a></div></div>)}
            <a href="/news">News</a>
          </nav>
          <div class="nav-ctas"><a class="btn btn-primary" href={downloadUrl} target="_blank" rel="noopener">Free Download</a><button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'"><span></span><span></span><span></span></button></div>
        </div>
        <nav class="mobile-nav"><a href="/">Home</a>{site.navDropdown?.items?.map((item) => <a class="sub" href={item.url}>{item.label}</a>)}{site.navItems?.map((item) => <a href={homeUrl(item.url)}>{item.label}</a>)}<a href="/news">News</a><a href="/comparison">Compare Solutions</a></nav>
      </div>
    </header>

    <main>
      <section class="page-hero">
        <div class="wrap">
          <div class="breadcrumb"><a href="/">Home</a><span class="breadcrumb-sep">&rsaquo;</span>Speech Recognition Software</div>
          <div class="page-hero-inner">
            <div>
              <div class="pill-badge">Free Edition Available - Windows</div>
              <h1>SpeechRecognition.cloud - AI Speech-to-Text for Windows</h1>
              <p class="subhead">Modern AI speech recognition that installs on Windows and dictates directly into any application. No voice training. No clunky dictation boxes. Just speak and watch your words appear in Word, Outlook, Teams, your EMR - anywhere you type.</p>
              <div class="hero-actions">
                <a href={downloadUrl} class="btn btn-primary btn-lg" target="_blank" rel="noopener">Free Download &rarr;</a>
                <a href="#editions" class="btn btn-outline btn-lg">View editions</a>
              </div>
            </div>
            <div>
              {heroSrc && (<div class="hero-img"><img src={heroSrc} alt={imgAlt("src-hero") || "SpeechRecognition.cloud Windows speech to text software"} loading="eager" decoding="async" /></div>)}
            </div>
          </div>
          <div class="stats-stripe">
            <div class="stats-row">
              <div class="stat-item"><div class="stat-val">99%</div><div class="stat-lbl">Accuracy</div></div>
              <div class="stat-item"><div class="stat-val">3x</div><div class="stat-lbl">Faster than typing</div></div>
              <div class="stat-item"><div class="stat-val">57+</div><div class="stat-lbl">Languages</div></div>
              <div class="stat-item"><div class="stat-val">20+</div><div class="stat-lbl">AI voice commands</div></div>
              <div class="stat-item"><div class="stat-val">Free</div><div class="stat-lbl">Starter edition</div></div>
            </div>
          </div>
        </div>
      </section>

      <div class="section-divider"></div>

      <section id="what-is-src" class="section-white">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <div class="sh">
                <h2>What is SpeechRecognition.cloud?</h2>
                <p>A modern Windows speech recognition app built to replace ageing dictation software without the complexity or cost.</p>
              </div>
              <p style="font-size:15px;line-height:1.7;color:#374151;margin:0 0 16px">SpeechRecognition.cloud is a Windows application developed by Voice Recognition Australia - the same team that has been deploying Dragon and dictation solutions across Australian healthcare, legal, and enterprise environments for 25 years.</p>
              <p style="font-size:15px;line-height:1.7;color:#374151;margin:0 0 16px">It installs on Windows and dictates directly into any application - Word, Outlook, Teams, Chrome, your practice management system, your EMR. There are no dictation boxes or intermediate steps. You speak and the text appears exactly where your cursor is.</p>
              <p style="font-size:15px;line-height:1.7;color:#374151;margin:0">Unlike older dictation software, it requires no voice training before you can start, and AI handles punctuation automatically. It is designed for professionals who are frustrated with expensive upgrade cycles, serial number headaches, and compatibility problems from legacy speech recognition products.</p>
            </div>
            <div class="c5">
              {featureSrc && (<div class="feature-img" style="margin-top:8px"><img src={featureSrc} alt={imgAlt("src-feature") || "SpeechRecognition.cloud dictating into Windows"} loading="lazy" decoding="async" /></div>)}
              <div class="card" style="margin-top:16px">
                <h3>At a glance</h3>
                <ul class="feature-list">
                  <li><span class="feature-check">&#10003;</span>Installs on Windows - works in any app</li>
                  <li><span class="feature-check">&#10003;</span>No voice training required</li>
                  <li><span class="feature-check">&#10003;</span>Automatic AI punctuation</li>
                  <li><span class="feature-check">&#10003;</span>57+ languages supported</li>
                  <li><span class="feature-check">&#10003;</span>Free Starter edition available</li>
                  <li><span class="feature-check">&#10003;</span>Professional edition with AI features</li>
                  <li><span class="feature-check">&#10003;</span>Medical Ultra edition for healthcare</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="editions" class="section-neutral">
        <div class="wrap">
          <div class="sh">
            <h2>Editions and pricing</h2>
            <p>Start free and upgrade to the edition that suits your usage. All prices AUD inc GST.</p>
          </div>
          <div class="grid">
            <div class="c3">
              <div class="plan-card">
                <div class="plan-name">Starter</div>
                <div class="plan-price">Free</div>
                <div class="plan-period">20 min per month</div>
                <div class="plan-tag">No credit card</div>
                <ul class="plan-features">
                  <li><span class="ck">&#10003;</span>20 min usage per month</li>
                  <li><span class="ck">&#10003;</span>Works in any Windows app</li>
                  <li><span class="ck">&#10003;</span>Automatic punctuation</li>
                  <li><span class="ck">&#10003;</span>Highly accurate</li>
                </ul>
                <a href={downloadUrl} class="btn btn-primary" target="_blank" rel="noopener" style="width:100%;box-sizing:border-box;display:block;text-align:center">Free Download</a>
              </div>
            </div>
            <div class="c3">
              <div class="plan-card">
                <div class="plan-name">Personal / Educational</div>
                <div class="plan-price">$119</div>
                <div class="plan-period">AUD inc GST per year</div>
                <div class="plan-tag">Students &amp; individuals</div>
                <ul class="plan-features">
                  <li><span class="ck">&#10003;</span>Unlimited usage</li>
                  <li><span class="ck">&#10003;</span>Custom vocabulary</li>
                  <li><span class="ck">&#10003;</span>Text replacements</li>
                  <li><span class="ck">&#10003;</span>Email support</li>
                </ul>
                <a href={buyUrl} class="btn btn-dark" target="_blank" rel="noopener" style="width:100%;box-sizing:border-box;display:block;text-align:center">Buy via VRA &rarr;</a>
              </div>
            </div>
            <div class="c3">
              <div class="plan-card highlight">
                <div class="plan-name">Professional</div>
                <div class="plan-price">$239</div>
                <div class="plan-period">AUD inc GST per year</div>
                <div class="plan-tag">Most popular</div>
                <ul class="plan-features">
                  <li><span class="ck">&#10003;</span>Everything in Personal</li>
                  <li><span class="ck">&#10003;</span>20+ AI voice commands</li>
                  <li><span class="ck">&#10003;</span>Advanced AI features</li>
                  <li><span class="ck">&#10003;</span>Priority support</li>
                </ul>
                <a href={buyUrl} class="btn btn-primary" target="_blank" rel="noopener" style="width:100%;box-sizing:border-box;display:block;text-align:center">Buy via VRA &rarr;</a>
              </div>
            </div>
            <div class="c3">
              <div class="plan-card">
                <div class="plan-name">Medical Ultra</div>
                <div class="plan-price">$659</div>
                <div class="plan-period">AUD inc GST per year</div>
                <div class="plan-tag">Healthcare</div>
                <ul class="plan-features">
                  <li><span class="ck">&#10003;</span>Medical vocabulary built-in</li>
                  <li><span class="ck">&#10003;</span>Healthcare-grade accuracy</li>
                  <li><span class="ck">&#10003;</span>Suitable for clinical notes</li>
                  <li><span class="ck">&#10003;</span>Australian support included</li>
                </ul>
                <a href={buyUrl} class="btn btn-dark" target="_blank" rel="noopener" style="width:100%;box-sizing:border-box;display:block;text-align:center">Buy via VRA &rarr;</a>
              </div>
            </div>
          </div>
          <p style="font-size:12px;color:var(--muted);margin-top:14px">All prices AUD inc GST. Verify current pricing at voicerecognition.com.au before purchasing.</p>
        </div>
      </section>

      <section class="section-white">
        <div class="wrap">

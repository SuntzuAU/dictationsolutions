---
import site from "../site.config.json";
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About | {site.siteName}</title>
    <meta name="description" content="About Dictation Solutions Australia and Voice Recognition Australia - 25 years of dictation and speech recognition expertise." />
    <link rel="canonical" href="https://dictationsolutions.com.au/about" />
  </head>
  <body style="margin:0;font-family:system-ui,sans-serif;background:#fff;color:#111827">
    <div style="max-width:760px;margin:0 auto;padding:48px 24px">
      <a href="/" style="color:#16a34a;font-weight:600;font-size:14px">&larr; Back to home</a>
      <h1 style="font-size:32px;margin:24px 0 16px">About Dictation Solutions Australia</h1>
      <p style="color:#4b5563;font-size:17px;line-height:1.7">Dictation Solutions Australia is part of the Voice Recognition Australia network - Australia's longest-serving speech recognition and dictation specialist.</p>
      <p style="color:#4b5563">Our team has been deploying Dragon speech recognition software, Philips and Olympus dictation hardware, and cloud speech solutions across healthcare, legal, government and enterprise environments since the late 1990s.</p>
      <p style="color:#4b5563">We help organisations choose the right dictation and speech recognition solution for their workflow - hardware, software or a combination of both.</p>
      <p style="margin-top:32px"><a href="https://www.voicerecognition.com.au" style="color:#16a34a;font-weight:700">Visit Voice Recognition Australia &rarr;</a></p>
      <p style="color:#6b7280;font-size:13px;margin-top:32px">&copy; {year} {site.siteName}</p>
    </div>
  </body>
</html>

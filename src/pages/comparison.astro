---
import site from "../site.config.json";

const c = site.colours;
const primaryColour = c.primary || "#1f2937";
const canonicalUrl = site.domain + "/comparison";
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Compare Dictation Solutions | {site.siteName}</title>
    <meta name="description" content="Compare Dragon, Philips SpeechLive, Speech Recognition Cloud, and hardware solutions side-by-side to find the right fit for your workflow." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Compare Dictation Solutions" />
    <meta property="og:description" content="Side-by-side comparison of speech recognition and dictation tools." />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_AU" />

    <style is:inline define:vars={{
      bg: c.background,
      text: c.text,
      primary: c.primary,
      accent: c.accent,
      accentHover: c.accentHover,
      muted: c.muted,
      neutral: c.neutral,
    }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:1px solid #e2e8f0;z-index:100}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}
      .logo img{height:40px;width:auto}
      .nav-links{display:flex;gap:18px;font-size:14px;font-weight:500;color:#334155;align-items:center}
      .nav-links a:hover{color:var(--accent)}
      .nav-ctas{display:flex;gap:10px;align-items:center}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap}
      .btn-primary{background:var(--accent);border-color:var(--accent);color:#fff}
      .btn-primary:hover{background:var(--accentHover);border-color:var(--accentHover)}
      .btn-secondary{background:transparent;border-color:var(--primary);color:var(--primary)}
      .btn-secondary:hover{background:var(--primary);color:#fff}
      .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}
      .hamburger span{display:block;width:22px;height:2px;background:#334155;border-radius:2px}
      .mobile-nav{display:none;padding:12px 0 8px;border-top:1px solid #e2e8f0}
      .mobile-nav a{display:block;padding:10px 0;font-size:15px;font-weight:500;color:#334155;border-bottom:1px solid #f1f5f9}
      section{padding:32px 0}
      .hero{padding:36px 0;text-align:center}
      .hero h1{font-size:32px;margin:0 0 12px;letter-spacing:-0.025em}
      .hero p{font-size:15px;color:var(--muted);margin:0 0 20px;max-width:720px;line-height:1.7;margin-left:auto;margin-right:auto}
      .compare-table{width:100%;border-collapse:collapse;margin-top:20px}
      .compare-table th,.compare-table td{padding:14px 16px;text-align:left;border-bottom:1px solid #e5e7eb}
      .compare-table th{background:#f9fafb;font-weight:700;color:var(--text);font-size:14px}
      .compare-table td{font-size:13px;color:var(--muted)}
      .compare-table tr:last-child td{border-bottom:none}
      .check{color:#16a34a;font-weight:700}
      .x{color:#9ca3af}
      .compare-highlight{background:#f0fdf4}
      .src-row{background:#eff6ff}
      .card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:18px}
      .card h3{margin:0 0 8px;font-size:15px;font-weight:700}
      .card p{margin:0;font-size:13px;color:var(--muted);line-height:1.6}
      .product-link{color:var(--accent);font-weight:700;text-decoration:underline;text-underline-offset:2px}
      .product-link:hover{opacity:.8}
      footer{background:#111827;color:#6b7280;padding:20px 0;font-size:13px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#374151;line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid #1e293b}
      .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
      @media(max-width:900px){
        .compare-table{font-size:12px}
        .compare-table th,.compare-table td{padding:10px 12px}
      }
      @media(max-width:600px){
        .nav-links{display:none}
        .nav-ctas .btn-secondary{display:none}
        .hamburger{display:flex}
        .hero h1{font-size:24px}
        section{padding:20px 0}
        .compare-table{font-size:11px}
        .compare-table th,.compare-table td{padding:8px 10px}
      }
    </style>
  </head>
  <body>

    <header>
      <div class="wrap">
        <div class="nav">
          <div class="logo">
            <a href="/"><img src="/logo.png" alt={site.siteName} onerror="this.style.display='none'" width="160" height="40" /></a>
          </div>
          <nav class="nav-links" aria-label="Primary">
            {site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}
          </nav>
          <div class="nav-ctas">
            <a class="btn btn-secondary" href="/#final-cta">Contact Us</a>
            <a class="btn btn-primary" href={site.primaryCTA.url} target="_blank" rel="noopener">{site.primaryCTA.text}</a>
            <button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'">
              <span></span><span></span><span></span>
            </button>
          </div>
        </div>
        <nav class="mobile-nav" aria-label="Mobile navigation">
          {site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}
          <a href="/#final-cta" style="color:var(--accent);font-weight:700">Contact Us</a>
        </nav>
      </div>
    </header>

    <main>

      <section class="hero">
        <div class="wrap">
          <h1>Compare dictation solutions</h1>
          <p>Find the right tool for your workflow. Dragon, Speech Recognition Cloud, Philips SpeechLive, hardware — or combine them all.</p>
        </div>
      </section>

      <section>
        <div class="wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th>Solution</th>
                <th>Best for</th>
                <th>Custom vocabulary</th>
                <th>Cloud-based</th>
                <th>Macros / automation</th>
                <th>Approx. cost (AUD)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Dragon Professional 16</strong></td>
                <td>Heavy daily dictation, complex documents</td>
                <td class="check">Yes</td>
                <td class="x">No</td>
                <td class="check">Yes</td>
                <td><a href="https://www.voicerecognition.com.au/collections/dragon-professional" target="_blank" rel="noopener" class="product-link">From $994 &rarr;</a></td>
              </tr>
              <tr class="compare-highlight">
                <td><strong>Dragon Medical One</strong></td>
                <td>Healthcare professionals, clinical documentation</td>
                <td class="check">Yes (medical vocab)</td>
                <td class="check">Yes</td>
                <td class="x">No</td>
                <td><a href="https://www.voicerecognition.com.au/products/dragon-medical-one" target="_blank" rel="noopener" class="product-link">Enquire &rarr;</a></td>
              </tr>
              <tr>
                <td><strong>Dragon Professional Anywhere</strong></td>
                <td>Teams, hybrid work, any device</td>
                <td class="check">Yes</td>
                <td class="check">Yes</td>
                <td class="check">Yes</td>
                <td><a href="https://www.voicerecognition.com.au/collections/dragon-professional" target="_blank" rel="noopener" class="product-link">Enquire &rarr;</a></td>
              </tr>
              <tr class="src-row">
                <td><strong>Speech Recognition Cloud</strong></td>
                <td>Cloud-first users, 57+ languages, free to start</td>
                <td class="x">AI-assisted</td>
                <td class="check">Yes</td>
                <td class="check">20+ AI commands</td>
                <td><a href="https://www.speechrecognition.cloud" target="_blank" rel="noopener" class="product-link">Free download &rarr;</a></td>
              </tr>
              <tr>
                <td><strong>Philips SpeechLive</strong></td>
                <td>Shared transcription workflows, dictation to transcription</td>
                <td class="check">Yes</td>
                <td class="check">Yes</td>
                <td class="x">No</td>
                <td>Enquire for pricing</td>
              </tr>
              <tr>
                <td><strong>Dictation hardware (Philips, OM System)</strong></td>
                <td>Secure, offline, high-sensitivity environments</td>
                <td>N/A</td>
                <td class="x">No</td>
                <td>N/A</td>
                <td><a href="https://www.voicerecognition.com.au/collections/voice-recorder" target="_blank" rel="noopener" class="product-link">Browse hardware &rarr;</a></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section style="background:var(--neutral)">
        <div class="wrap">
          <h2 style="font-size:24px;margin:0 0 16px;font-weight:800">Key decision factors</h2>
          <div class="grid">
            <div class="card">
              <h3>Cloud vs local</h3>
              <p>Cloud tools (Dragon Anywhere, SpeechLive, Speech Recognition Cloud) work anywhere. Local tools (Dragon Professional desktop) offer offline capability and tighter data control.</p>
            </div>
            <div class="card">
              <h3>Custom vocabulary and macros</h3>
              <p>Dragon with custom macros can be 3x faster than typing. Philips excels at shared workflows. Speech Recognition Cloud offers 20+ AI commands without setup.</p>
            </div>
            <div class="card">
              <h3>Budget</h3>
              <p>Dragon Professional is a one-time cost (perpetual licence). Speech Recognition Cloud offers a free tier to start. Cloud subscriptions suit teams needing flexibility.</p>
            </div>
            <div class="card">
              <h3>Team workflows</h3>
              <p>Philips SpeechLive handles delegation between authors and transcriptionists. Dragon works best for individual power users who dictate heavily and automate repeatedly.</p>
            </div>
            <div class="card">
              <h3>Governance</h3>
              <p>Healthcare and government users need clear data retention, training, and compliance. Dragon Medical One and enterprise Philips include HIPAA/BAA options.</p>
            </div>
            <div class="card">
              <h3>Specialisation</h3>
              <p>Medical professionals benefit from Dragon Medical (built-in medical vocabulary). Lawyers and legal teams should use Philips SpeechLive with Dragon for document production.</p>
            </div>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <h2 style="font-size:24px;margin:0 0 12px;font-weight:800">Common combinations</h2>
          <div class="grid">
            <div style="background:#f0fdf4;border:1px solid #dcfce7;border-radius:12px;padding:18px">
              <h3 style="margin:0 0 8px;font-size:15px;font-weight:700">Medical professionals</h3>
              <p style="margin:0;font-size:13px;color:#374151;line-height:1.6">Dragon Medical One (primary) + Philips SpeechMike recorder (secure backup). For simpler needs, Speech Recognition Cloud with its free tier is a low-friction starting point.</p>
            </div>
            <div style="background:#f0fdf4;border:1px solid #dcfce7;border-radius:12px;padding:18px">
              <h3 style="margin:0 0 8px;font-size:15px;font-weight:700">Legal teams</h3>
              <p style="margin:0;font-size:13px;color:#374151;line-height:1.6">Philips SpeechLive (workflow) + Dragon Professional (personal power users). Speech Recognition Cloud suits fee earners who need fast, flexible dictation across devices.</p>
            </div>
            <div style="background:#f0fdf4;border:1px solid #dcfce7;border-radius:12px;padding:18px">
              <h3 style="margin:0 0 8px;font-size:15px;font-weight:700">Single-user heavy dictators</h3>
              <p style="margin:0;font-size:13px;color:#374151;line-height:1.6">Dragon Professional 16 (local, perpetual) + custom macros for workflows. Or Speech Recognition Cloud for a cloud-first alternative with no upfront cost.</p>
            </div>
            <div style="background:#f0fdf4;border:1px solid #dcfce7;border-radius:12px;padding:18px">
              <h3 style="margin:0 0 8px;font-size:15px;font-weight:700">Flexible / hybrid teams</h3>
              <p style="margin:0;font-size:13px;color:#374151;line-height:1.6">Dragon Professional Anywhere (cloud, all devices) + Philips SpeechMike hardware (for better audio in noisy environments).</p>
            </div>
            <div style="background:#f0fdf4;border:1px solid #dcfce7;border-radius:12px;padding:18px">
              <h3 style="margin:0 0 8px;font-size:15px;font-weight:700">Multilingual teams</h3>
              <p style="margin:0;font-size:13px;color:#374151;line-height:1.6">Speech Recognition Cloud (57+ languages, free tier) is the natural choice where English-only Dragon is not sufficient. No training required, works instantly.</p>
            </div>
            <div style="background:#f0fdf4;border:1px solid #dcfce7;border-radius:12px;padding:18px">
              <h3 style="margin:0 0 8px;font-size:15px;font-weight:700">Government agencies</h3>
              <p style="margin:0;font-size:13px;color:#374151;line-height:1.6">On-premises or containerised Dragon + Philips hardware for secure capture + auditable workflows with retention controls.</p>
            </div>
          </div>
        </div>
      </section>

      <section style={`background:${primaryColour};padding:36px 0`}>
        <div class="wrap">
          <h2 style="font-size:24px;margin:0 0 8px;font-weight:800;color:white">Not sure which solution is right for you?</h2>
          <p style="font-size:15px;color:#9ca3af;margin:0 0 20px;max-width:640px">Talk to our team. We have helped hundreds of Australian professionals, legal firms, and healthcare organisations choose the right combination. 25 years of deployment experience.</p>
          <a href="/#final-cta" class="btn btn-primary" style="background:var(--accent);border-color:var(--accent)">Contact Us</a>
        </div>
      </section>

    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">
            {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
          </div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>

  </body>
</html>

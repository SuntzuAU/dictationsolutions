---
import site from "../site.config.json";
import ACForm from "../components/ACForm.astro";
import Nav from "../components/Nav.astro";

const year = new Date().getFullYear();
const c = site.colours;
const product = site.products.find(p => p.slug === "dragon-medical-one");
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{product?.metaTitle || "Dragon Medical One Australia | Dictation Solutions"}</title>
    <meta name="description" content={product?.metaDesc || "Dragon Medical One for Australian clinicians. Cloud-based medical speech recognition with speciality vocabularies and EHR integration."} />
    <link rel="canonical" href="https://dictationsolutions.com.au/dragon-medical-one" />
    <style is:inline define:vars={{ bg: c.background, text: c.text, primary: c.primary, accent: c.accent, accentHover: c.accentHover, muted: c.muted, neutral: c.neutral }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      .page-hero{background:linear-gradient(135deg,var(--primary) 0%,#1e40af 100%);color:white;padding:28px 0 24px}
      .breadcrumb{font-size:12px;color:rgba(255,255,255,.6);margin-bottom:12px;font-weight:500}
      .breadcrumb a{color:rgba(255,255,255,.85);font-weight:600}
      h1{font-size:34px;line-height:1.1;margin:0 0 10px;letter-spacing:-0.025em;font-weight:800}
      .intro{font-size:16px;color:rgba(255,255,255,.75);margin:0;line-height:1.6}
      .section-divider{height:4px;background:linear-gradient(90deg,var(--accent),var(--primary))}
      section{padding:24px 0}
      .section-neutral{background:var(--neutral)}
      .section-dark{background:var(--primary);color:white}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}.c4{grid-column:span 4}.c7{grid-column:span 7}.c5{grid-column:span 5}.c12{grid-column:span 12}
      .sh{margin-bottom:14px}
      .sh h2{font-size:24px;letter-spacing:-0.02em;margin:0 0 5px;font-weight:800}
      .sh p{font-size:15px;margin:0;color:var(--muted)}
      .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:20px}
      .card h2,.card h3{margin:0 0 8px;font-weight:800}
      .card p{color:var(--muted);margin:0 0 10px;font-size:14px;line-height:1.55}
      .card p:last-of-type{margin-bottom:0}
      .card ul{color:var(--muted);padding-left:18px;margin:0 0 14px;line-height:2;font-size:14px}
      .tag{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;background:var(--accent);color:#fff;margin-bottom:10px;text-transform:uppercase;letter-spacing:.05em}
      .tag-gray{background:#6b7280}
      .faq-card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:16px;border-left:4px solid var(--accent)}
      .faq-card h3{margin:0 0 5px;font-size:14px;font-weight:700;color:var(--primary)}
      .faq-card p{margin:0;font-size:13px;color:var(--muted);line-height:1.55}
      .btn{display:inline-block;padding:10px 22px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;text-align:center}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}
      .btn-primary{background:var(--accent);border-color:var(--accent);color:#fff}
      .btn-primary:hover{background:var(--accentHover)}
      .btn-ghost{background:transparent;border-color:rgba(255,255,255,.4);color:white}
      .btn-ghost:hover{background:rgba(255,255,255,.1);border-color:white}
      .formbox{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:14px;padding:20px}
      footer{background:#0f172a;color:#6b7280;padding:16px 0;font-size:13px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#374151;line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid #1e293b}
      @media(max-width:900px){.c6,.c4,.c5,.c7{grid-column:span 12}h1{font-size:26px}}
      @media(max-width:600px){section{padding:16px 0}.card{padding:14px}.page-hero{padding:20px 0 18px}}
    </style>
  </head>
  <body>
    <Nav currentPath="/dragon-medical-one" />

    <div class="page-hero">
      <div class="wrap">
        <div class="breadcrumb"><a href="/">Home</a> &rsaquo; <a href="/#products">Products</a> &rsaquo; Dragon Medical One</div>
        <h1>Dragon Medical One</h1>
        <p class="intro">Cloud-based AI clinical documentation for Australian healthcare. Medical vocabularies, EHR integration, and ambient AI that reduces documentation burden for clinicians.</p>
        <div style="display:flex;gap:12px;margin-top:18px;flex-wrap:wrap">
          <a href="https://www.voicerecognition.com.au/pages/dragon-medical-one" class="btn btn-primary btn-lg" target="_blank" rel="noopener">Request a Quote &rarr;</a>
          <a href="#contact" class="btn btn-ghost btn-lg">Talk to VRA &mdash; local support</a>
        </div>
      </div>
    </div>
    <div class="section-divider"></div>

    <main>
      <section>
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              <div class="sh">
                <h2>What is Dragon Medical One?</h2>
                <p>Cloud-based speech recognition built specifically for clinical documentation.</p>
              </div>
              <p style="font-size:15px;color:var(--muted);margin:0 0 12px">Dragon Medical One is a cloud-based speech recognition platform developed by Nuance (Microsoft) specifically for healthcare documentation. Clinicians dictate directly into electronic health records, clinical notes, and patient documentation using their voice &mdash; in real time, with no generative AI component. What you say is what appears.</p>
              <p style="font-size:15px;color:var(--muted);margin:0 0 12px">Unlike Dragon Professional, Dragon Medical One includes built-in medical speciality vocabularies covering cardiology, radiology, pathology, oncology, emergency medicine, general practice, and 35+ others. No custom training required to get started.</p>
              <p style="font-size:15px;color:var(--muted);margin:0 0 16px">It is a subscription service &mdash; no local installation required. Clinicians can dictate from a desktop, laptop, tablet, or mobile device with an internet connection. Profile syncs automatically across all devices.</p>
              <h3 style="font-size:18px;font-weight:800;margin:0 0 8px">Who uses Dragon Medical One in Australia?</h3>
              <p style="font-size:15px;color:var(--muted);margin:0 0 12px">General practitioners, specialists, radiologists, pathologists, and clinicians across 40+ specialties who need to produce clinical documentation efficiently. Particularly well suited to practices where doctors are responsible for their own documentation.</p>
              <p style="font-size:15px;color:var(--muted)">For Australian pricing and purchasing, <a href="https://www.voicerecognition.com.au" style="color:var(--accent);font-weight:600">Voice Recognition Australia</a> is the authorised Nuance/Microsoft reseller. Pricing is subscription-based per user per year &mdash; contact VRA for current rates.</p>
            </div>
            <div class="c5">
              <div class="card" style="border-color:var(--accent);border-width:2px">
                <div class="tag">Healthcare</div>
                <h3 style="font-size:17px">Key features</h3>
                <ul>
                  {product?.features?.map(f => <li>{f}</li>)}
                </ul>
                <a href="https://www.voicerecognition.com.au/pages/dragon-medical-one" class="btn btn-primary" style="display:block;text-align:center" target="_blank" rel="noopener">Get Australian pricing &rarr;</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="section-divider"></div>

      <section class="section-neutral">
        <div class="wrap">
          <div class="sh">
            <h2>Dragon Medical One vs Dragon Medical Practice Edition</h2>
            <p>The current cloud platform vs the legacy desktop product.</p>
          </div>
          <div class="grid">
            <div class="card c6" style="border-color:var(--accent)">
              <div class="tag">Current</div>
              <h3>Dragon Medical One</h3>
              <p>Cloud-based. Subscription per user per year. No local installation. Works from any device with internet. Automatic vocabulary updates. Enterprise management tools. Actively developed by Nuance/Microsoft.</p>
            </div>
            <div class="card c6">
              <div class="tag tag-gray">Legacy</div>
              <h3>Dragon Medical Practice Edition</h3>
              <p>Locally installed Windows software. Perpetual licence. Required local installation and voice profile training. No longer actively developed or sold. If you are still running DMPE, migration to Dragon Medical One is the recommended path.</p>
            </div>
          </div>
          <p style="color:var(--muted);font-size:13px;margin-top:14px">For migration assistance from Dragon Medical Practice Edition, contact <a href="https://www.voicerecognition.com.au" style="color:var(--accent)">Voice Recognition Australia</a>.</p>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="sh">
            <h2>Frequently asked questions</h2>
          </div>
          <div class="grid">
            {product?.faqs?.map(f => (
              <div class="faq-card c6">
                <h3>{f.q}</h3>
                <p>{f.a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="contact" class="section-dark">
        <div class="wrap">
          <div class="grid" style="align-items:start">
            <div class="c7" style="padding:16px 0">
              <h2 style="color:white;font-size:22px;margin:0 0 8px;font-weight:800">Enquire about Dragon Medical One</h2>
              <p style="color:rgba(255,255,255,.7);margin:0 0 14px;font-size:14px">Our team can advise on Dragon Medical One pricing, deployment, EHR compatibility, and setup for Australian healthcare environments.</p>
              <ul style="color:rgba(255,255,255,.65);padding-left:18px;line-height:2;font-size:14px;margin:0">
                <li>Current Australian pricing</li>
                <li>EHR and EMR compatibility</li>
                <li>Microphone recommendations</li>
                <li>Migration from older Dragon Medical products</li>
              </ul>
            </div>
            <div class="c5" style="padding:16px 0">
              <div class="formbox"><ACForm /></div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">
            {site.footerLinks?.map(l => <a href={l.url}>{l.label}</a>)}
          </div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>
  </body>
</html>

  }

  .ac-form-wrapper #_form_287_ ._full_width {
    width: 100%;
  }

  .ac-form-wrapper #_form_287_ ._button-wrapper {
    margin-top: 4px;
  }

  .ac-form-wrapper #_form_287_ input[type="text"]._has_error,
  .ac-form-wrapper #_form_287_ textarea._has_error {
    border-color: #f87171 !important;
    background: #fef2f2;
  }

  .ac-form-wrapper #_form_287_ ._error {
    display: block;
    position: absolute;
    font-size: 12px;
    z-index: 10000001;
  }

  .ac-form-wrapper #_form_287_ ._error._above {
    padding-bottom: 4px;
    bottom: 39px;
    right: 0;
  }

  .ac-form-wrapper #_form_287_ ._error._below {
    padding-top: 8px;
    top: 100%;
    right: 0;
  }

  .ac-form-wrapper #_form_287_ ._error-inner {
    padding: 8px 12px 8px 28px;
    background-color: #fee2e2;
    background-image: url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill-rule='evenodd' clip-rule='evenodd' d='M16 8C16 12.4183 12.4183 16 8 16C3.58172 16 0 12.4183 0 8C0 3.58172 3.58172 0 8 0C12.4183 0 16 3.58172 16 8ZM9 3V9H7V3H9ZM9 13V11H7V13H9Z' fill='%23CA0000'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: 8px center;
    background-size: 14px 14px;
    font-size: 12px;
    font-weight: 600;
    line-height: 16px;
    color: #7f1d1d;
    text-align: left;
    border-radius: 6px;
    box-shadow: 0 1px 4px rgba(31,33,41,.2);
  }

  .ac-form-wrapper #_form_287_ ._error-inner._form_error {
    margin-bottom: 5px;
    text-align: left;
  }

  .ac-form-wrapper #_form_287_ ._error-inner._no_arrow {
    margin-bottom: 10px;
  }

  .ac-form-wrapper #_form_287_ ._error-arrow {
    position: absolute;
    width: 0;
    height: 0;
  }

  .ac-form-wrapper #_form_287_ ._error._above ._error-arrow {
    bottom: -4px;
    right: 15px;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-top: 8px solid #fee2e2;
  }

  .ac-form-wrapper #_form_287_ ._error._below ._error-arrow {
    top: 0;
    right: 15px;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-bottom: 8px solid #fee2e2;
  }

  .ac-form-wrapper #_form_287_ ._form-thank-you {
    position: relative;
    text-align: center;
    font-size: 16px;
    line-height: 1.6;

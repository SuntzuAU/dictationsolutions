---
import site from "../site.config.json";
import manifest from "../data/image-manifest.json";
import ACForm from "../components/ACForm.astro";

const product = site.products.find(p => p.slug === 'dragon-medical-one');
const c = site.colours;
const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}
function imgAlt(key) { return manifest[key]?.altText || ""; }
function homeUrl(url) {
  if (!url) return "/";
  return url.startsWith("#") ? `/${url}` : url;
}

const heroKey = product.heroImageKey || "hero";
const featureKey = product.featureImageKey || "feature-dictation";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{product.metaTitle}</title>
    <meta name="description" content={product.metaDesc} />
    <link rel="canonical" href={`${site.domain}/${product.slug}`} />
    {site.googleAnalyticsId && (<script async src={`https://www.googletagmanager.com/gtag/js?id=${site.googleAnalyticsId}`}></script><script define:vars={{ gaId: site.googleAnalyticsId }}>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config',gaId);</script>)}
    <style is:inline define:vars={{ bg: c.background, text: c.text, primary: c.primary, accent: c.accent, accentHover: c.accentHover, muted: c.muted, neutral: c.neutral }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:2px solid var(--accent);z-index:200}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}
      .logo img{height:42px;width:auto}
      .nav-links{display:flex;gap:20px;font-size:14px;font-weight:600;color:#374151;align-items:center}
      .nav-links > a{white-space:nowrap;padding:4px 0;border-bottom:2px solid transparent;transition:color .15s,border-color .15s}
      .nav-links > a:hover{color:var(--accent);border-bottom-color:var(--accent)}
      .dropdown{position:relative}
      .dropdown-toggle{cursor:pointer;display:flex;align-items:center;gap:4px;white-space:nowrap;padding:4px 0;border-bottom:2px solid transparent;transition:color .15s,border-color .15s}
      .dropdown-toggle:hover,.dropdown:hover .dropdown-toggle{color:var(--accent);border-bottom-color:var(--accent)}
      .dropdown-toggle svg{transition:transform .2s;flex-shrink:0}
      .dropdown:hover .dropdown-toggle svg{transform:rotate(180deg)}
      .dropdown-menu{display:none;position:fixed;top:auto;left:auto;background:#fff;border:1px solid #e5e7eb;border-top:3px solid var(--accent);border-radius:0 0 12px 12px;box-shadow:0 12px 40px rgba(0,0,0,.12);min-width:230px;padding:6px 0;z-index:9999}
      .dropdown:hover .dropdown-menu{display:block}
      .dropdown-menu a{display:block;padding:11px 18px;font-size:13px;font-weight:600;color:#374151;transition:background .1s,color .1s;border-bottom:1px solid #f3f4f6}
      .dropdown-menu a:last-child{border-bottom:none}
      .dropdown-menu a:hover{background:#f0f9ff;color:var(--accent)}
      .nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;text-align:center}
      .btn-primary{background:var(--accent);border-color:var(--accent);color:#fff}
      .btn-primary:hover{background:var(--accentHover);border-color:var(--accentHover);transform:translateY(-1px)}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}
      .btn-dark{background:#1f2937;border-color:#1f2937;color:#fff}
      .btn-dark:hover{background:#374151;border-color:#374151;transform:translateY(-1px)}
      .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}
      .hamburger span{display:block;width:22px;height:2px;background:#374151;border-radius:2px}
      .mobile-nav{display:none;padding:10px 0 8px;border-top:1px solid #e5e7eb}
      .mobile-nav a{display:block;padding:10px 4px;font-size:15px;font-weight:600;color:#374151;border-bottom:1px solid #f3f4f6}
      .mobile-nav a.sub{padding-left:16px;font-weight:500;font-size:14px;color:#6b7280}
      section{padding:22px 0}
      .product-hero{padding:24px 0 28px;background:linear-gradient(135deg,#1a2f5e 0%,#1e3a5f 60%,#16a34a 100%);color:white}
      .breadcrumb{font-size:12px;color:rgba(255,255,255,.6);margin-bottom:14px;font-weight:500}
      .breadcrumb a{color:rgba(255,255,255,.85);font-weight:600}
      .breadcrumb a:hover{color:white}
      .breadcrumb-sep{margin:0 6px;color:rgba(255,255,255,.4)}
      .product-hero-inner{display:grid;grid-template-columns:1.1fr 0.9fr;gap:36px;align-items:start}
      .licence-badge{display:inline-block;font-size:11px;font-weight:700;padding:4px 12px;border-radius:999px;margin-bottom:12px;text-transform:uppercase;letter-spacing:.06em;background:var(--accent);color:#fff}
      .product-hero h1{font-size:32px;line-height:1.1;margin:0 0 10px;letter-spacing:-0.03em;font-weight:800;color:white}
      .product-hero .subhead{font-size:15px;line-height:1.65;margin:0 0 18px;color:rgba(255,255,255,.8)}
      .price-display{font-size:44px;font-weight:800;line-height:1;color:white;margin:0 0 2px}
      .price-note{font-size:13px;color:rgba(255,255,255,.65);margin:0 0 6px}
      .licence-note{font-size:13px;color:rgba(255,255,255,.8);margin:0 0 20px;padding:10px 14px;background:rgba(255,255,255,.1);border-radius:8px;border-left:3px solid var(--accent)}
      .buy-actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
      .stat-trio{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:16px}
      .stat-box{text-align:center;padding:12px 8px;background:rgba(255,255,255,.12);border-radius:10px;border:1px solid rgba(255,255,255,.2)}
      .stat-box-val{font-size:15px;font-weight:800;color:#fff;line-height:1.1}
      .stat-box-lbl{font-size:10px;color:rgba(255,255,255,.6);margin-top:3px;text-transform:uppercase;letter-spacing:.04em}
      .sh{margin-bottom:14px}
      .sh h2{font-size:24px;letter-spacing:-0.02em;margin:0 0 5px;font-weight:800}
      .sh p{font-size:15px;margin:0;color:var(--muted)}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}.c4{grid-column:span 4}.c5{grid-column:span 5}.c7{grid-column:span 7}.c12{grid-column:span 12}
      .section-white{background:#fff}.section-neutral{background:var(--neutral)}.section-dark{background:var(--primary);color:white}
      .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:18px}
      .feature-list{list-style:none;padding:0;margin:0}
      .feature-list li{padding:8px 0;border-bottom:1px solid #f3f4f6;font-size:14px;display:flex;gap:10px;align-items:flex-start;line-height:1.5}
      .feature-list li:last-child{border-bottom:none}
      .feature-check{color:var(--accent);font-weight:700;flex-shrink:0}
      .faq-card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:16px;border-left:4px solid var(--accent)}
      .faq-card h3{margin:0 0 5px;font-size:14px;font-weight:700;color:var(--primary)}
      .faq-card p{margin:0;font-size:13px;color:var(--muted);line-height:1.55}
      .other-versions{display:flex;flex-wrap:wrap;gap:10px;margin-top:6px}
      .other-version-link{padding:8px 16px;border-radius:8px;border:2px solid #e5e7eb;font-size:13px;font-weight:600;color:#374151;transition:all .15s}
      .other-version-link:hover{border-color:var(--accent);color:var(--accent)}
      .feature-image{border-radius:12px;overflow:hidden;margin-top:12px;box-shadow:0 8px 24px rgba(0,0,0,.08)}
      .feature-image img{width:100%;height:auto;display:block}
      .section-divider{height:4px;background:linear-gradient(90deg,var(--accent),var(--primary))}
      .cta-section{background:var(--primary);padding:48px 0}
      .cta-inner{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
      .cta-image{border-radius:16px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 50px rgba(0,0,0,.4)}
      .cta-image img{width:100%;height:100%;object-fit:cover;display:block}
      .cta-text{color:white}
      .cta-text h2{font-size:26px;font-weight:800;margin:0 0 10px;color:white;line-height:1.2}
      .cta-text p{font-size:14px;color:rgba(255,255,255,.75);margin:0 0 16px;line-height:1.65}
      .cta-text ul{color:rgba(255,255,255,.7);margin:0 0 24px;padding-left:18px;font-size:14px;line-height:2}
      .cta-text .cta-btn{display:inline-block;padding:12px 24px;background:var(--accent);color:#fff;border-radius:8px;font-weight:700;font-size:14px;transition:background .15s}
      .cta-text .cta-btn:hover{background:var(--accentHover)}
      .formbox{background:#fff;border-radius:16px;padding:28px;box-shadow:0 8px 32px rgba(0,0,0,.2)}
      .formbox-heading{font-size:18px;font-weight:800;color:var(--primary);margin:0 0 4px}
      .formbox-sub{font-size:13px;color:var(--muted);margin:0 0 18px}
      footer{background:#0f172a;color:#6b7280;padding:16px 0;font-size:13px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#374151;line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid #1e293b}
      @media(max-width:900px){.product-hero-inner{grid-template-columns:1fr}.product-hero h1{font-size:26px}.c6,.c4,.c5,.c7{grid-column:span 12}.sh h2{font-size:20px}.cta-inner{grid-template-columns:1fr}}
      @media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}section{padding:14px 0}.product-hero{padding:16px 0 18px}.card,.faq-card,.formbox{padding:14px}.price-display{font-size:32px}.buy-actions{flex-direction:column}.buy-actions .btn-lg{width:100%;text-align:center}.footer-inner{flex-direction:column;align-items:center;text-align:center}.footer-links{justify-content:center}.cta-section{padding:28px 0}}
    </style>
  </head>
  <body>
    <header>
      <div class="wrap">
        <div class="nav">
          <div class="logo"><a href="/"><img src="/logo.png" alt={site.siteName} onerror="this.style.display='none'" width="160" height="40" /></a></div>
          <nav class="nav-links" aria-label="Primary">
            {site.navItems?.map((item) => <a href={homeUrl(item.url)}>{item.label}</a>)}
            {site.navDropdown && (<div class="dropdown"><span class="dropdown-toggle">{site.navDropdown.label}<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span><div class="dropdown-menu">{site.navDropdown.items?.map((item) => <a href={item.url}>{item.label}</a>)}<a href="/comparison">Compare Solutions</a></div></div>)}
            <a href="/news">News</a>
          </nav>
          <div class="nav-ctas"><a class="btn btn-primary" href="/#final-cta">{site.primaryCTA.text}</a><button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'"><span></span><span></span><span></span></button></div>
        </div>
        <nav class="mobile-nav"><a href="/">Home</a>{site.navDropdown?.items?.map((item) => <a class="sub" href={item.url}>{item.label}</a>)}{site.navItems?.map((item) => <a href={homeUrl(item.url)}>{item.label}</a>)}<a href="/news">News</a><a href="/comparison">Compare Solutions</a></nav>
      </div>
    </header>
    <main>
      <section class="product-hero">
        <div class="wrap">
          <div class="breadcrumb"><a href="/">Home</a><span class="breadcrumb-sep">&rsaquo;</span><a href="/#products">Products</a><span class="breadcrumb-sep">&rsaquo;</span>{product.title}</div>
          <div class="product-hero-inner">
            <div>
              <div class="licence-badge">{product.badge}</div>
              <h1>{product.headline}</h1>
              <p class="subhead">{product.subheadline}</p>
              <div style="margin-bottom:6px"><div class="price-display">{product.price}</div><div class="price-note">{product.priceNote}</div></div>
              <div class="licence-note">{product.licenceNote}</div>
              <div class="buy-actions">
                <a href={product.vraUrl} class="btn btn-primary btn-lg" target="_blank" rel="noopener">{product.ctaText} &rarr;</a>
                <a href="#final-cta" class="btn btn-dark btn-lg">Talk to our team</a>
              </div>
            </div>
            <div>
              {imgSrc(heroKey) && (<div style="border-radius:14px;overflow:hidden;aspect-ratio:4/3;box-shadow:0 20px 50px rgba(0,0,0,.3)"><img src={imgSrc(heroKey)} alt={imgAlt(heroKey) || product.title} loading="eager" decoding="async" style="width:100%;height:100%;object-fit:cover" /></div>)}
              <div class="stat-trio">
                <div class="stat-box"><div class="stat-box-val">{product.price}</div><div class="stat-box-lbl">Price</div></div>
                <div class="stat-box"><div class="stat-box-val">{product.installLimit}</div><div class="stat-box-lbl">Licence</div></div>
                <div class="stat-box"><div class="stat-box-val">{product.bestFor?.split(' ').slice(0,2).join(' ')}</div><div class="stat-box-lbl">Best for</div></div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <div class="section-divider"></div>
      <section class="section-neutral"><div class="wrap"><div class="grid"><div class="c7"><div class="sh"><h2>What's included</h2><p>Everything you get with {product.title}.</p></div><div class="card"><ul class="feature-list">{product.features?.map((f) => (<li><span class="feature-check">&#10003;</span>{f}</li>))}</ul></div></div><div class="c5">{imgSrc(featureKey) && (<div class="feature-image" style="margin-top:46px"><img src={imgSrc(featureKey)} alt={imgAlt(featureKey)} loading="lazy" decoding="async" /></div>)}</div></div></div></section>
      <section class="section-white"><div class="wrap"><div class="sh"><h2>Frequently asked questions</h2></div><div class="grid">{product.faqs?.map((f) => (<div class="faq-card c6"><h3>{f.q}</h3><p>{f.a}</p></div>))}</div></div></section>
      <section class="section-neutral"><div class="wrap"><div class="sh"><h2>Other solutions</h2><p>Compare other dictation and transcription solutions.</p></div><div class="other-versions">{site.products?.filter(p => p.slug !== product.slug).map(p => (<a href={`/${p.slug}`} class="other-version-link">{p.navLabel || p.title} &mdash; {p.price}</a>))}</div><div style="margin-top:16px"><a href="/" class="btn btn-primary">View all solutions</a></div></div></section>
      <section id="final-cta" class="cta-section">
        <div class="wrap">
          <div class="cta-inner">
            <div>
              {imgSrc(heroKey) && (<div class="cta-image"><img src={imgSrc(heroKey)} alt={imgAlt(heroKey) || product.title} loading="lazy" decoding="async" /></div>)}
              <div class="cta-text" style="margin-top:24px">
                <h2>Questions about {product.title}?</h2>
                <p>Our team has been helping Australian professionals choose dictation and speech recognition solutions for 25 years. Tell us about your situation and we will recommend the right option.</p>
                <ul>
                  <li>How many users and what type of work</li>
                  <li>Windows, Mac, or cloud preference</li>
                  <li>Healthcare, legal, or general professional use</li>
                  <li>Budget and licensing preferences</li>
                </ul>
                <a href={product.vraUrl} class="cta-btn" target="_blank" rel="noopener">{product.ctaText} &rarr;</a>
              </div>
            </div>
            <div class="formbox">
              <div class="formbox-heading">Get in touch</div>
              <div class="formbox-sub">Local Australian support. Fast response.</div>
              <ACForm />
            </div>
          </div>
        </div>
      </section>
    </main>
    <footer><div class="wrap"><div class="footer-inner"><div>&copy; {year} {site.siteName}</div><div class="footer-links">{site.footerLinks?.map((l) => <a href={homeUrl(l.url)}>{l.label}</a>)}</div></div><div class="footer-disclaimer">{site.branding.footerDisclaimer}</div></div></footer>
  </body>
</html>

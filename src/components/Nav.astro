---
import site from "../site.config.json";
const { currentPath = '' } = Astro.props;
const c = site.colours;

function homeUrl(url) {
  if (!url) return "/";
  return url.startsWith("#") ? `/${url}` : url;
}
---

<header>
  <div class="wrap">
    <div class="nav">
      <div class="logo">
        <a href="/"><img src="/logo.png" alt={site.siteName} onerror="this.style.display='none'" width="160" height="40" /></a>
      </div>
      <nav class="nav-main" aria-label="Primary navigation">
        {site.navItems?.map((item) => (
          <a href={homeUrl(item.url)} class={currentPath === item.url ? 'active' : ''}>{item.label}</a>
        ))}
        {site.navDropdown && (
          <div class="dropdown">
            <span class="dropdown-toggle">
              {site.navDropdown.label}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </span>
            <div class="dropdown-menu">
              {site.navDropdown.items?.map((item) => (
                <a href={item.url}>{item.label}</a>
              ))}
              <a href="/comparison">Compare Solutions</a>
            </div>
          </div>
        )}
        <a href="/news" class={currentPath === '/news' ? 'active' : ''}>News</a>
      </nav>
      <div class="nav-ctas">
        <a class="nav-btn-primary" href={site.primaryCTA.url} target="_blank" rel="noopener">{site.primaryCTA.text}</a>
        <button class="hamburger" aria-label="Open menu" onclick="var mn=this.closest('header').querySelector('.mobile-nav');mn.style.display=mn.style.display==='block'?'none':'block'">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
    <nav class="mobile-nav" aria-label="Mobile navigation">
      <a href="/">Home</a>
      {site.navItems?.map((item) => <a href={homeUrl(item.url)}>{item.label}</a>)}
      {site.navDropdown?.items?.map((item) => <a class="sub" href={item.url}>{item.label}</a>)}
      <a href="/comparison">Compare Solutions</a>
      <a href="/news">News</a>
      <a class="sub" href={site.primaryCTA.url} target="_blank" rel="noopener">{site.primaryCTA.text}</a>
    </nav>
  </div>
</header>

<style is:inline define:vars={{
  accent: c.accent,
  accentHover: c.accentHover,
  primary: c.primary,
  text: c.text,
  muted: c.muted,
  neutral: c.neutral,
  bg: c.background,
}}>
  header{position:sticky;top:0;background:rgba(255,255,255,.97);backdrop-filter:blur(12px);border-bottom:2px solid var(--accent);z-index:200;overflow:visible}
  .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
  .nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}
  .logo img{height:42px;width:auto}
  .nav-main{display:flex;gap:20px;font-size:14px;font-weight:600;color:#374151;align-items:center}
  .nav-main > a{white-space:nowrap;padding:4px 0;border-bottom:2px solid transparent;transition:color .15s,border-color .15s;color:#374151;text-decoration:none}
  .nav-main > a:hover,.nav-main > a.active{color:var(--accent);border-bottom-color:var(--accent)}
  .dropdown{position:relative}
  .dropdown-toggle{cursor:pointer;display:flex;align-items:center;gap:4px;white-space:nowrap;padding:4px 0;border-bottom:2px solid transparent;transition:color .15s,border-color .15s;font-size:14px;font-weight:600;color:#374151}
  .dropdown-toggle:hover,.dropdown:hover .dropdown-toggle{color:var(--accent);border-bottom-color:var(--accent)}
  .dropdown-toggle svg{transition:transform .2s;flex-shrink:0}
  .dropdown:hover .dropdown-toggle svg{transform:rotate(180deg)}
  .dropdown-menu{display:none;position:absolute;top:100%;left:0;background:#fff;border:1px solid #e2e8f0;border-top:2px solid var(--accent);border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.1);min-width:220px;padding:8px 0 6px;z-index:300}
  .dropdown:hover .dropdown-menu{display:block}
  .dropdown-menu a{display:block;padding:10px 16px;font-size:14px;font-weight:500;color:#374151;transition:background .1s,color .1s;border-bottom:1px solid #f3f4f6;text-decoration:none}
  .dropdown-menu a:last-child{border-bottom:none}
  .dropdown-menu a:hover{background:#f0fdf4;color:var(--accent)}
  .nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}
  .nav-btn-primary{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;background:var(--accent);color:#fff;border:2px solid var(--accent);cursor:pointer;transition:all .15s;white-space:nowrap;text-decoration:none}
  .nav-btn-primary:hover{background:var(--accentHover);border-color:var(--accentHover)}
  .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px;background:none;border:none}
  .hamburger span{display:block;width:22px;height:2px;background:#374151;border-radius:2px}
  .mobile-nav{display:none;padding:10px 0 8px;border-top:1px solid #e5e7eb}
  .mobile-nav a{display:block;padding:10px 4px;font-size:15px;font-weight:600;color:#374151;border-bottom:1px solid #f3f4f6;text-decoration:none}
  .mobile-nav a.sub{padding-left:16px;font-weight:500;font-size:14px;color:#6b7280}
  @media(max-width:600px){
    .nav-main{display:none}
    .nav-btn-primary{padding:8px 14px;font-size:13px}
    .hamburger{display:flex}
  }
</style>

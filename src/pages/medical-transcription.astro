---
import site from "../site.config.json";
import ACForm from "../components/ACForm.astro";
import Nav from "../components/Nav.astro";
const year = new Date().getFullYear();
const c = site.colours;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Medical Transcription Australia | Dragon, AI Scribes &amp; Dictation Workflows | Dictation Solutions</title>
    <meta name="description" content="Medical transcription solutions for Australian healthcare. Traditional dictation workflows, Dragon Medical One, Dragon Copilot ambient AI, and AI scribes compared. Expert local advice." />
    <link rel="canonical" href="https://dictationsolutions.com.au/medical-transcription" />
    <style is:inline define:vars={{ bg: c.background, text: c.text, primary: c.primary, accent: c.accent, accentHover: c.accentHover, muted: c.muted, neutral: c.neutral }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      .page-hero{background:linear-gradient(135deg,var(--primary) 0%,#1e40af 100%);color:white;padding:28px 0 24px}
      .breadcrumb{font-size:12px;color:rgba(255,255,255,.6);margin-bottom:12px;font-weight:500}
      .breadcrumb a{color:rgba(255,255,255,.85);font-weight:600}
      h1{font-size:34px;line-height:1.1;margin:0 0 10px;letter-spacing:-0.025em;font-weight:800}
      .intro{font-size:16px;color:rgba(255,255,255,.75);margin:0;line-height:1.6}
      .section-divider{height:4px;background:linear-gradient(90deg,var(--accent),var(--primary))}
      section{padding:24px 0}
      .section-neutral{background:var(--neutral)}
      .section-dark{background:var(--primary);color:white}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}.c4{grid-column:span 4}.c7{grid-column:span 7}.c5{grid-column:span 5}.c12{grid-column:span 12}
      .sh{margin-bottom:14px}
      .sh h2{font-size:24px;letter-spacing:-0.02em;margin:0 0 5px;font-weight:800}
      .sh p{font-size:15px;margin:0;color:var(--muted)}
      .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:20px}
      .card h3{margin:0 0 8px;font-size:17px;font-weight:800}.card p{color:var(--muted);margin:0 0 10px;font-size:14px;line-height:1.55}
      .card p:last-of-type{margin-bottom:0}
      .tag{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;background:var(--accent);color:#fff;margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em}
      .tag-blue{background:#2563eb}
      .tag-purple{background:#7c3aed}
      .tag-gray{background:#6b7280}
      .notice{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:16px 20px;margin-top:14px}
      .notice p{margin:0;font-size:14px;color:#166534;line-height:1.55}
      .warning-box{background:#fff7ed;border:1px solid #fed7aa;border-radius:10px;padding:16px 20px;margin-top:12px}
      .warning-box p{margin:0;font-size:13px;color:#9a3412;line-height:1.55}
      .cite{font-size:12px;color:#6b7280;font-style:italic;margin-top:8px}
      .formbox{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:14px;padding:20px}
      footer{background:#0f172a;color:#6b7280;padding:16px 0;font-size:13px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}.footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#374151;line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid #1e293b}
      @media(max-width:900px){.c6,.c4,.c5,.c7{grid-column:span 12}h1{font-size:26px}}
      @media(max-width:600px){section{padding:16px 0}.card{padding:14px}}
    </style>
  </head>
  <body>
    <Nav currentPath="/medical-transcription" />

    <div class="page-hero">
      <div class="wrap">
        <div class="breadcrumb"><a href="/">Home</a> &rsaquo; Medical Transcription</div>
        <h1>Medical Transcription Australia</h1>
        <p class="intro">From traditional dictation workflows to ambient AI documentation &mdash; understanding your options for clinical practice.</p>
      </div>
    </div>
    <div class="section-divider"></div>

    <main>
      <section>
        <div class="wrap">
          <div style="max-width:720px">
            <h2 style="font-size:22px;margin:0 0 10px;font-weight:800">Four approaches to medical documentation</h2>
            <p style="font-size:15px;color:var(--muted);margin:0 0 10px">Medical documentation has always competed with patient care for a clinician's time. The tools available to reduce that burden have shifted considerably &mdash; from traditional dictation and human transcription, through real-time speech recognition, to ambient AI systems that listen to the consultation itself and draft notes automatically.</p>
            <p style="font-size:15px;color:var(--muted)">Each approach suits different workflows, documentation environments, and preferences. Understanding how they differ &mdash; particularly around accuracy, verbatim output, and governance &mdash; matters when choosing what is right for your practice.</p>
          </div>
        </div>
      </section>

      <div class="section-divider"></div>

      <section class="section-neutral">
        <div class="wrap">
          <div class="sh">
            <h2>Comparing the approaches</h2>
            <p>Four workflows for clinical documentation &mdash; from traditional to ambient AI.</p>
          </div>
          <div class="grid">
            <div class="card c6">
              <div class="tag tag-gray">Traditional</div>
              <h3>Dictation + Transcription</h3>
              <p>The clinician dictates using a voice recorder or smartphone app. The audio file is routed to a transcriptionist who reviews and finalises the document. No direct software interaction during the consultation.</p>
              <p><a href="https://www.voicerecognition.com.au/collections/philips-speechlive" style="color:var(--accent);font-weight:600">Philips SpeechLive</a> is a cloud-based dictation and transcription workflow platform widely used in Australian legal and professional environments. Hosted on Microsoft Azure with end-to-end encryption and ISO 27001 compliance.</p>
            </div>

            <div class="card c6" style="border-color:var(--accent);border-width:2px">
              <div class="tag">Recommended</div>
              <h3>Dragon Medical One</h3>
              <p>Dragon Medical One converts voice to text in real time as you dictate directly into your EHR or document. It is <strong>verbatim</strong> &mdash; it transcribes exactly what you say, with no generative component.</p>
              <p>Built-in medical vocabularies cover cardiology, radiology, pathology, emergency medicine, general practice and 35+ more specialties. Cloud-based &mdash; accessible from any device, no local installation.</p>
              <a href="/dragon-medical-one" style="color:var(--accent);font-weight:600;font-size:13px">Dragon Medical One details &rarr;</a>
            </div>

            <div class="card c6">
              <div class="tag tag-blue">Ambient AI</div>
              <h3>Dragon Copilot</h3>
              <p>Dragon Copilot extends Dragon Medical One with ambient AI capability. Rather than dictating directly, Dragon Copilot listens to the consultation itself and generates structured clinical notes from the conversation &mdash; reducing cognitive interruption during the encounter.</p>
              <p>A 2025 peer-reviewed study in ScienceDirect found significant reductions in daily documentation time and self-reported off-hours documentation burden among participating clinicians.</p>
              <p class="cite">Source: "Deploying ambient clinical intelligence to improve care", ScienceDirect, 2025.</p>
            </div>

            <div class="card c6">
              <div class="tag tag-purple">AI Medical Scribes</div>
              <h3>Heidi and Lyrebird Health</h3>
              <p>Australian-relevant AI scribe tools that use ambient listening to generate clinical notes from consultations. Both position themselves around Australian privacy compliance.</p>
              <p>Heidi and Lyrebird use generative AI to produce notes &mdash; they interpret and construct output based on what was heard, not verbatim transcription. Clinician review of all generated notes before they enter the medical record is non-negotiable.</p>
              <div class="warning-box">
                <p><strong>Verbatim vs generative AI:</strong> Dragon Medical One transcribes exactly what you say. AI scribes interpret and summarise. Neither is categorically superior, but understanding which type of output you are working with is a genuine clinical governance consideration.</p>
              </div>
            </div>
          </div>

          <div class="notice">
            <p><strong>The verbatim question:</strong> Dragon Medical One is a verbatim tool &mdash; what you say is what appears. Dragon Copilot and AI scribes are generative &mdash; they interpret and construct. Understanding this distinction matters for clinical governance.</p>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div style="max-width:700px">
            <h2 style="font-size:22px;margin:0 0 10px;font-weight:800">Privacy and data governance in Australian healthcare</h2>
            <p style="font-size:15px;color:var(--muted);margin:0 0 10px">Australian health information is treated as sensitive information under the Privacy Act, attracting stricter handling requirements. For any speech or transcription tool used in clinical practice, the practical questions are: where does audio and transcript data reside, how long is it retained, who has access, and what are the contractual commitments around model training?</p>
            <p style="font-size:15px;color:var(--muted)">Dragon Medical One carries Microsoft/Nuance enterprise-grade security documentation. Philips SpeechLive publishes explicit statements that data is not used to train AI models without permission. Heidi and Lyrebird both publish security documentation &mdash; confirm Australian data residency requirements are met before clinical deployment.</p>
          </div>
        </div>
      </section>

      <section class="section-dark">
        <div class="wrap">
          <div class="grid" style="align-items:start">
            <div class="c7" style="padding:16px 0">
              <h2 style="color:white;font-size:22px;margin:0 0 8px;font-weight:800">Not sure which approach suits your practice?</h2>
              <p style="color:rgba(255,255,255,.7);font-size:14px;margin:0">Our team can walk you through the options based on your specialty, patient volume, EHR system and how your clinical team currently handles documentation.</p>
            </div>
            <div class="c5" style="padding:16px 0">
              <div class="formbox"><ACForm /></div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">
            {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
          </div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>
  </body>
</html>

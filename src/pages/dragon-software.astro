---
import manifest from "../data/image-manifest.json";
import site from "../site.config.json";
import ACForm from "../components/ACForm.astro";
import Nav from "../components/Nav.astro";

const year = new Date().getFullYear();
const c = site.colours;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dragon Software Australia | Professional, Medical &amp; Anywhere | Dictation Solutions</title>
    <meta name="description" content="Dragon speech recognition software for Australian professionals. Dragon Professional 16, Dragon Medical One, and Dragon Professional Anywhere. Authorised reseller with local support." />
    <link rel="canonical" href="https://dictationsolutions.com.au/dragon-software" />
    <style is:inline define:vars={{ bg: c.background, text: c.text, primary: c.primary, accent: c.accent, accentHover: c.accentHover, muted: c.muted, neutral: c.neutral }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      .page-hero{background:linear-gradient(135deg,var(--primary) 0%,#1e40af 100%);color:white;padding:28px 0 24px}
      .breadcrumb{font-size:12px;color:rgba(255,255,255,.6);margin-bottom:12px;font-weight:500}
      .breadcrumb a{color:rgba(255,255,255,.85);font-weight:600}
      .breadcrumb a:hover{color:white}
      h1{font-size:34px;line-height:1.1;margin:0 0 10px;letter-spacing:-0.025em;font-weight:800}
      .intro{font-size:16px;color:rgba(255,255,255,.75);margin:0;line-height:1.6}
      .section-divider{height:4px;background:linear-gradient(90deg,var(--accent),var(--primary))}
      section{padding:24px 0}
      .section-neutral{background:var(--neutral)}
      .section-dark{background:var(--primary);color:white}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}.c4{grid-column:span 4}.c7{grid-column:span 7}.c5{grid-column:span 5}.c12{grid-column:span 12}
      .sh{margin-bottom:14px}
      .sh h2{font-size:24px;letter-spacing:-0.02em;margin:0 0 5px;font-weight:800}
      .sh p{font-size:15px;margin:0;color:var(--muted)}
      .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:20px;display:flex;flex-direction:column}
      .card h2{font-size:18px;margin:0 0 6px;font-weight:800}
      .card p{color:var(--muted);margin:0 0 12px;font-size:14px;line-height:1.55;flex:1}
      .card ul{color:var(--muted);padding-left:18px;margin:0 0 14px;line-height:1.9;font-size:13px}
      .tag{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;background:var(--accent);color:#fff;margin-bottom:10px;text-transform:uppercase;letter-spacing:.05em}
      .tag-cloud{background:#2563eb}
      .tag-medical{background:#dc2626}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;text-align:center;margin-top:auto}
      .btn-primary{background:var(--accent);border-color:var(--accent);color:#fff}
      .btn-primary:hover{background:var(--accentHover);border-color:var(--accentHover)}
      .btn-outline{border:2px solid var(--accent);color:var(--accent);background:transparent}
      .btn-outline:hover{background:var(--accent);color:#fff}
      .btn-ghost{background:transparent;border-color:rgba(255,255,255,.4);color:white}
      .btn-ghost:hover{background:rgba(255,255,255,.1);border-color:white}
      .compare-table{width:100%;border-collapse:collapse;font-size:14px}
      .compare-table th,.compare-table td{padding:12px 16px;text-align:left;border-bottom:1px solid #e5e7eb}
      .compare-table th{background:#f9fafb;font-weight:700;color:#374151}
      .compare-table tr:last-child td{border-bottom:none}
      .compare-yes{color:var(--accent);font-weight:700}
      .compare-no{color:#9ca3af}
      .formbox{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:14px;padding:20px}
      footer{background:#0f172a;color:#6b7280;padding:16px 0;font-size:13px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#374151;line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid #1e293b}
      @media(max-width:900px){.c6,.c4,.c5,.c7{grid-column:span 12}h1{font-size:26px}}
      @media(max-width:600px){section{padding:16px 0}.card{padding:14px}.compare-table{font-size:12px}.compare-table th,.compare-table td{padding:9px 12px}}
    </style>
  </head>
  <body>
    <Nav currentPath="/dragon-software" />

    <div class="page-hero">
      <div class="wrap">
        <div class="breadcrumb"><a href="/">Home</a> &rsaquo; Dragon Software</div>
        <h1>Dragon Speech Recognition Software</h1>
        <p class="intro">Desktop, cloud and healthcare editions for Australian professionals &mdash; from an authorised Nuance/Microsoft reseller with 25 years local support.</p>
      </div>
    </div>
    <div class="section-divider"></div>

    <main>

      <section>
        <div class="wrap">
          <div class="sh">
            <h2>The Dragon product range</h2>
            <p>Three editions covering desktop, cloud and clinical documentation workflows.</p>
          </div>
          <div class="grid">

            <div class="card c4">
              <div class="tag">Desktop</div>
              <h2>Dragon Professional 16</h2>
              <p>Locally installed Windows software. Works completely offline after activation. Perpetual licence &mdash; buy once, own it. The choice for legal, government and professionals with strict data handling requirements.</p>
              <ul>
                <li>Works offline &mdash; no internet needed</li>
                <li>Custom vocabulary and voice macros</li>
                <li>Transcribe single-speaker audio files</li>
                <li>Windows 10 and 11</li>
                <li>Install on up to 2 PCs</li>
              </ul>
              <a href="/dragon-professional-16" class="btn btn-outline">Full details &rarr;</a>
            </div>

            <div class="card c4" style="border-color:var(--accent);border-width:2px">
              <div class="tag tag-cloud">Cloud</div>
              <h2>Dragon Professional Anywhere</h2>
              <p>Full Dragon Professional power delivered from the cloud. Works on Windows and Mac. No local installation. Centralised management for enterprise deployments. Annual subscription.</p>
              <ul>
                <li>Windows and Mac compatible</li>
                <li>No local installation required</li>
                <li>Unlimited device access</li>
                <li>Enterprise management console</li>
                <li>Consistent profile across devices</li>
              </ul>
              <a href="/dragon-professional-anywhere" class="btn btn-primary">Enquire for pricing &rarr;</a>
            </div>

            <div class="card c4">
              <div class="tag tag-medical">Healthcare</div>
              <h2>Dragon Medical One</h2>
              <p>Cloud-based speech recognition built specifically for clinicians. Built-in medical speciality vocabularies, EHR integration, ambient AI documentation. The leading choice for Australian healthcare.</p>
              <ul>
                <li>40+ medical specialty vocabularies</li>
                <li>EHR and EMR integration</li>
                <li>Dictate from any device</li>
                <li>Ambient AI via Dragon Copilot</li>
                <li>Cloud &mdash; no local installation</li>
              </ul>
              <a href="/dragon-medical-one" class="btn btn-outline">Full details &rarr;</a>
            </div>

          </div>
        </div>
      </section>

      <div class="section-divider"></div>

      <section class="section-neutral">
        <div class="wrap">
          <div class="sh">
            <h2>Side-by-side comparison</h2>
            <p>Key differences at a glance.</p>
          </div>
          <div class="card c12" style="padding:0;overflow:hidden">
            <table class="compare-table">
              <thead>
                <tr>
                  <th>Feature</th>
                  <th>Professional 16</th>
                  <th>Professional Anywhere</th>
                  <th>Medical One</th>
                </tr>
              </thead>
              <tbody>
                <tr><td>Works offline</td><td class="compare-yes">Yes</td><td class="compare-no">No</td><td class="compare-no">No</td></tr>
                <tr><td>Mac support</td><td class="compare-no">No</td><td class="compare-yes">Yes</td><td class="compare-yes">Yes</td></tr>
                <tr><td>Medical vocabularies</td><td class="compare-no">No</td><td class="compare-no">No</td><td class="compare-yes">Yes (40+ specialties)</td></tr>
                <tr><td>Licensing</td><td>Perpetual (own it)</td><td>Annual subscription</td><td>Annual subscription</td></tr>
                <tr><td>Installation</td><td>Local (Windows)</td><td>Cloud (any device)</td><td>Cloud (any device)</td></tr>
                <tr><td>Best for</td><td>Legal, Govt, heavy dictators</td><td>Enterprise, multi-device</td><td>Clinicians, healthcare</td></tr>
                <tr><td>Price</td><td>$994 AUD inc GST</td><td>Enquire</td><td>Enquire</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div style="max-width:700px">
            <h2 style="font-size:22px;margin:0 0 10px;font-weight:800">Desktop vs cloud: which Dragon is right for you?</h2>
            <p style="color:var(--muted);font-size:15px;margin:0 0 12px">The main question is whether you need to work offline. Dragon Professional 16 installs locally and runs without an internet connection &mdash; important for legal, government and healthcare environments with strict data requirements.</p>
            <p style="color:var(--muted);font-size:15px;margin:0 0 12px">Dragon Professional Anywhere and Dragon Medical One are cloud-based and require internet. In return, they offer anywhere access, automatic updates, Mac support, and enterprise management without local IT overhead.</p>
            <p style="color:var(--muted);font-size:15px;margin:0 0 16px">For purchasing and current Australian pricing, <a href="https://www.voicerecognition.com.au" style="color:var(--accent);font-weight:600">Voice Recognition Australia</a> is the authorised Australian reseller for the full Dragon range.</p>
            <a href="/#final-cta" class="btn btn-primary">Talk to our team &rarr;</a>
          </div>
        </div>
      </section>

      <section class="section-dark">
        <div class="wrap">
          <div class="grid" style="align-items:start">
            <div class="c7" style="padding:16px 0">
              <h2 style="color:white;font-size:22px;margin:0 0 8px;font-weight:800">Not sure which Dragon is right for you?</h2>
              <p style="color:rgba(255,255,255,.7);margin:0 0 16px;font-size:14px">Our team has been deploying Dragon software in Australian organisations for 25 years. Tell us about your workflow and we will recommend the right option.</p>
              <a href="https://www.voicerecognition.com.au" class="btn btn-primary" target="_blank" rel="noopener">Browse Dragon at VRA &rarr;</a>
            </div>
            <div class="c5" style="padding:16px 0">
              <div class="formbox"><ACForm /></div>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">
            {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
          </div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>
  </body>
</html>

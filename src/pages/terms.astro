---
import site from "../site.config.json";
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Terms of Use | {site.siteName}</title>
    <meta name="robots" content="noindex" />
  </head>
  <body style="margin:0;font-family:system-ui,sans-serif;background:#fff;color:#0f1a10">
    <div style="max-width:760px;margin:0 auto;padding:48px 24px">
      <a href="/" style="color:#2d7a3a;font-weight:600;font-size:14px">&larr; Back to home</a>
      <h1 style="font-size:32px;margin:24px 0 16px">Terms of Use</h1>
      <p style="color:#4a5e4d">The information on this website is provided for general guidance only. While Voice Recognition Australia takes care to keep information accurate and current, product specifications, pricing, and availability are subject to change without notice. All transactions are subject to the terms and conditions of Voice Recognition Australia.</p>
      <p style="color:#64748b;font-size:13px;margin-top:32px">&copy; {year} {site.siteName}</p>
    </div>
  </body>
</html>

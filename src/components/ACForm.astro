<style is:global>
  .ac-form-wrapper #_form_287_ {
    font-size: 14px;
    line-height: 1.6;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    margin: 0;
    background: transparent;
    border: none;
    padding: 0;
    box-shadow: none;
    max-width: 100%;
  }

  .ac-form-wrapper #_form_287_ input[type="text"],
  .ac-form-wrapper #_form_287_ input[type="tel"],
  .ac-form-wrapper #_form_287_ textarea {
    padding: 10px 12px;
    height: auto;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    color: #000 !important;
    font-size: 14px;
    box-sizing: border-box;
    font-family: inherit;
    width: 100%;
    display: block;
    margin-bottom: 12px;
  }

  .ac-form-wrapper #_form_287_ input::placeholder {
    color: #9ca3af;
  }

  .ac-form-wrapper #_form_287_ textarea {
    resize: vertical;
    min-height: 100px;
  }

  .ac-form-wrapper #_form_287_ ._submit {
    cursor: pointer;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    background: #16a34a !important;
    border: 1px solid #16a34a !important;
    border-radius: 8px !important;
    color: #fff !important;
    padding: 12px 24px !important;
    width: 100%;
    transition: background 0.15s;
  }

  .ac-form-wrapper #_form_287_ ._submit:hover {
    background: #15803d !important;
    border-color: #15803d !important;
  }

  .ac-form-wrapper #_form_287_ ._submit:disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .ac-form-wrapper #_form_287_ ._submit.processing {
    position: relative;
  }

  .ac-form-wrapper #_form_287_ ._submit.processing::before {
    content: "";
    width: 1em;
    height: 1em;
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 50%;
    border: double 3px transparent;
    border-radius: 50%;
    background-image: linear-gradient(#16a34a, #16a34a), conic-gradient(#16a34a, #fff);
    background-origin: border-box;
    background-clip: content-box, border-box;
    animation: 1200ms ease 0s infinite normal none running _spin;
  }

  .ac-form-wrapper #_form_287_ ._form-content {
    margin-bottom: 0;
  }

  .ac-form-wrapper #_form_287_ ._form_element {
    position: relative;
    margin-bottom: 0;

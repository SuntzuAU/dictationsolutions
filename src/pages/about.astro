---
import site from "../site.config.json";
import Nav from "../components/Nav.astro";
const year = new Date().getFullYear();
const c = site.colours;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About | {site.siteName}</title>
    <meta name="description" content="About Dictation Solutions Australia and Voice Recognition Australia - 25 years of dictation and speech recognition expertise." />
    <link rel="canonical" href="https://dictationsolutions.com.au/about" />
    <style is:inline define:vars={{ bg: c.background, text: c.text, primary: c.primary, accent: c.accent, muted: c.muted, neutral: c.neutral }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      .page-hero{background:linear-gradient(135deg,var(--primary) 0%,#1e40af 100%);color:white;padding:28px 0 24px}
      .breadcrumb{font-size:12px;color:rgba(255,255,255,.6);margin-bottom:12px;font-weight:500}
      .breadcrumb a{color:rgba(255,255,255,.85);font-weight:600}
      h1{font-size:34px;line-height:1.1;margin:0 0 10px;letter-spacing:-0.025em;font-weight:800}
      .section-divider{height:4px;background:linear-gradient(90deg,var(--accent),var(--primary))}
      .content{max-width:760px;padding:32px 0}
      .content p{color:var(--muted);font-size:16px;line-height:1.75;margin:0 0 16px}
      .content p:last-of-type{margin-bottom:0}
      footer{background:#0f172a;color:#6b7280;padding:16px 0;font-size:13px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}.footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#374151;line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid #1e293b}
    </style>
  </head>
  <body>
    <Nav currentPath="/about" />

    <div class="page-hero">
      <div class="wrap">
        <div class="breadcrumb"><a href="/">Home</a> &rsaquo; About</div>
        <h1>About Dictation Solutions Australia</h1>
      </div>
    </div>
    <div class="section-divider"></div>

    <main>
      <div class="wrap">
        <div class="content">
          <p>Dictation Solutions Australia is part of the Voice Recognition Australia network - Australia's longest-serving speech recognition and dictation specialist.</p>
          <p>Our team has been deploying Dragon speech recognition software, Philips and Olympus dictation hardware, and cloud speech solutions across healthcare, legal, government and enterprise environments since the late 1990s.</p>
          <p>We help organisations choose the right dictation and speech recognition solution for their workflow - hardware, software or a combination of both.</p>
          <p style="margin-top:8px"><a href="https://www.voicerecognition.com.au" style="color:var(--accent);font-weight:700">Visit Voice Recognition Australia &rarr;</a></p>
        </div>
      </div>
    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">
            {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
          </div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>
  </body>
</html>

---
import site from "../site.config.json";
import ACForm from "../components/ACForm.astro";
import Nav from "../components/Nav.astro";
const year = new Date().getFullYear();
const c = site.colours;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Speech-to-Text Software Australia | Dragon, Cloud &amp; AI Options | Dictation Solutions</title>
    <meta name="description" content="Speech-to-text software for Australian professionals. Compare Dragon Professional 16, Dragon Medical One, cloud AI platforms and browser-based transcription. Expert advice and local support." />
    <link rel="canonical" href="https://dictationsolutions.com.au/speech-to-text" />
    <style is:inline define:vars={{ bg: c.background, text: c.text, primary: c.primary, accent: c.accent, accentHover: c.accentHover, muted: c.muted, neutral: c.neutral }}>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,sans-serif;line-height:1.6;background:var(--bg);color:var(--text)}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      .page-hero{background:linear-gradient(135deg,var(--primary) 0%,#1e40af 100%);color:white;padding:28px 0 24px}
      .breadcrumb{font-size:12px;color:rgba(255,255,255,.6);margin-bottom:12px;font-weight:500}
      .breadcrumb a{color:rgba(255,255,255,.85);font-weight:600}
      h1{font-size:34px;line-height:1.1;margin:0 0 10px;letter-spacing:-0.025em;font-weight:800}
      .intro{font-size:16px;color:rgba(255,255,255,.75);margin:0;line-height:1.6}
      .section-divider{height:4px;background:linear-gradient(90deg,var(--accent),var(--primary))}
      section{padding:24px 0}
      .section-neutral{background:var(--neutral)}
      .section-dark{background:var(--primary);color:white}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}.c4{grid-column:span 4}.c7{grid-column:span 7}.c5{grid-column:span 5}.c12{grid-column:span 12}
      .sh{margin-bottom:14px}
      .sh h2{font-size:24px;letter-spacing:-0.02em;margin:0 0 5px;font-weight:800}
      .sh p{font-size:15px;margin:0;color:var(--muted)}
      .card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:20px;display:flex;flex-direction:column}
      .card h3{margin:0 0 6px;font-size:17px;font-weight:800}
      .card p{color:var(--muted);margin:0 0 10px;font-size:14px;line-height:1.55;flex:1}
      .tag{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;background:var(--accent);color:#fff;margin-bottom:8px;text-transform:uppercase;letter-spacing:.04em}
      .tag-cloud{background:#2563eb}
      .tag-medical{background:#dc2626}
      .feature-row{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid #f3f4f6;font-size:14px}
      .feature-row:last-child{border-bottom:none}
      .feature-check{color:var(--accent);font-weight:700;flex-shrink:0;font-size:16px}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;text-align:center;margin-top:auto}
      .btn-primary{background:var(--accent);border-color:var(--accent);color:#fff}
      .btn-primary:hover{background:var(--accentHover)}
      .btn-outline{border:2px solid var(--accent);color:var(--accent);background:transparent}
      .btn-outline:hover{background:var(--accent);color:#fff}
      .formbox{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:14px;padding:20px}
      footer{background:#0f172a;color:#6b7280;padding:16px 0;font-size:13px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}.footer-links a:hover{color:white}
      .footer-disclaimer{font-size:11px;color:#374151;line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid #1e293b}
      @media(max-width:900px){.c6,.c4,.c5,.c7{grid-column:span 12}h1{font-size:26px}}
      @media(max-width:600px){section{padding:16px 0}.card{padding:14px}}
    </style>
  </head>
  <body>
    <Nav currentPath="/speech-to-text" />

    <div class="page-hero">
      <div class="wrap">
        <div class="breadcrumb"><a href="/">Home</a> &rsaquo; Speech-to-Text</div>
        <h1>Speech-to-Text Software Australia</h1>
        <p class="intro">Comparing Dragon, cloud AI and browser-based transcription for Australian professionals &mdash; expert advice to choose the right tool for your workflow.</p>
      </div>
    </div>
    <div class="section-divider"></div>

    <main>

      <section>
        <div class="wrap">
          <div style="max-width:700px">
            <h2 style="font-size:22px;margin:0 0 10px;font-weight:800">Which speech-to-text solution is right for you?</h2>
            <p style="font-size:15px;color:var(--muted);margin:0 0 10px">Speech-to-text covers a wide range of products and use cases. At one end, Dragon Professional installs locally on Windows, works offline, and provides deep application integration and voice command automation. At the other end, cloud-based platforms work in any browser, support dozens of languages, and require no software installation.</p>
            <p style="font-size:15px;color:var(--muted)">For healthcare, Dragon Medical One is purpose-built with medical vocabularies and EHR integration. For general professional use, Dragon Professional is the market standard for accuracy and workflow automation. Our team at <a href="https://www.voicerecognition.com.au" style="color:var(--accent);font-weight:600">Voice Recognition Australia</a> can help you work through the options.</p>
          </div>
        </div>
      </section>

      <div class="section-divider"></div>

      <section class="section-neutral">
        <div class="wrap">
          <div class="sh">
            <h2>Compare speech-to-text options</h2>
            <p>Three main approaches for Australian professionals.</p>
          </div>
          <div class="grid">
            <div class="card c4">
              <div class="tag">Desktop</div>
              <h3>Dragon Professional 16</h3>
              <p>Locally installed, works offline, Windows only. Best accuracy for professional use. Custom vocabulary and voice macros. Perpetual licence &mdash; buy once, own it.</p>
              <div style="margin:8px 0 12px">
                <div class="feature-row"><span class="feature-check">&#10003;</span> Works completely offline</div>
                <div class="feature-row"><span class="feature-check">&#10003;</span> Custom vocabulary &amp; macros</div>
                <div class="feature-row"><span class="feature-check">&#10003;</span> Transcribe audio files</div>
                <div class="feature-row"><span class="feature-check">&#10003;</span> From $994 AUD inc GST</div>
              </div>
              <a href="/dragon-professional-16" class="btn btn-outline">Full details &rarr;</a>
            </div>
            <div class="card c4" style="border-color:var(--accent);border-width:2px">
              <div class="tag tag-cloud">Cloud AI</div>
              <h3>SpeechRecognition Cloud</h3>
              <p>Browser-based, 57 languages, no installation required. Free tier available. Modern AI platform built by Voice Recognition Australia for individuals and teams.</p>
              <div style="margin:8px 0 12px">
                <div class="feature-row"><span class="feature-check">&#10003;</span> Any browser, any device</div>
                <div class="feature-row"><span class="feature-check">&#10003;</span> 57 languages supported</div>
                <div class="feature-row"><span class="feature-check">&#10003;</span> Free tier available</div>
                <div class="feature-row"><span class="feature-check">&#10003;</span> Medical tier for clinicians</div>
              </div>
              <a href="https://www.speechrecognition.cloud" class="btn btn-primary" target="_blank" rel="noopener">Try it free &rarr;</a>
            </div>
            <div class="card c4">
              <div class="tag tag-medical">Healthcare</div>
              <h3>Dragon Medical One</h3>
              <p>Cloud-based, purpose-built for clinical documentation. Medical specialty vocabularies, EHR integration, ambient AI via Dragon Copilot. Subscription per clinician.</p>
              <div style="margin:8px 0 12px">
                <div class="feature-row"><span class="feature-check">&#10003;</span> 40+ medical vocabularies</div>
                <div class="feature-row"><span class="feature-check">&#10003;</span> EHR integration</div>
                <div class="feature-row"><span class="feature-check">&#10003;</span> Any device, cloud-based</div>
                <div class="feature-row"><span class="feature-check">&#10003;</span> Ambient AI via Copilot</div>
              </div>
              <a href="/dragon-medical-one" class="btn btn-outline">Full details &rarr;</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section-dark">
        <div class="wrap">
          <div class="grid" style="align-items:start">
            <div class="c7" style="padding:16px 0">
              <h2 style="color:white;font-size:22px;margin:0 0 8px;font-weight:800">Need help choosing?</h2>
              <p style="color:rgba(255,255,255,.7);font-size:14px;margin:0">Tell us about your workflow and we will recommend the most suitable speech-to-text option for your situation.</p>
            </div>
            <div class="c5" style="padding:16px 0">
              <div class="formbox"><ACForm /></div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>&copy; {year} {site.siteName}</div>
          <div class="footer-links">
            {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
          </div>
        </div>
        <div class="footer-disclaimer">{site.branding.footerDisclaimer}</div>
      </div>
    </footer>
  </body>
</html>

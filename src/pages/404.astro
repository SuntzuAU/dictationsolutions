---
import site from "../site.config.json";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found | {site.siteName}</title>
  </head>
  <body style="margin:0;font-family:system-ui,sans-serif;background:#fff;color:#0f1a10;display:flex;align-items:center;justify-content:center;min-height:100vh">
    <div style="text-align:center;padding:40px 24px">
      <div style="font-size:64px;font-weight:800;color:#2d7a3a">404</div>
      <h1 style="margin:8px 0 12px">Page not found</h1>
      <p style="color:#4a5e4d;margin:0 0 24px">This page does not exist. Let's get you back on track.</p>
      <a href="/" style="display:inline-block;padding:12px 24px;background:#2d7a3a;color:#fff;border-radius:8px;font-weight:700;text-decoration:none">Back to home</a>
    </div>
  </body>
</html>
